         "2": "spu_UpdateSireIds",
         "3": " CREATE PROCEDURE spu_UpdateSireIds  AS  DECLARE @strTableWithOldAnimalIds VARCHAR(1000)  DECLARE @strTableWithNewAnimalIds VARCHAR(1000)  DECLARE @strFieldsToJoinFrom VARCHAR(8000)  DECLARE @strFieldsToJoinTo VARCHAR(8000)    /*SET @strFieldsToJoinFrom = 'Breed,HBN,Sex,Sr_Code,HBN_Flag'  SET @strFieldsToJoinTo   = 'Breed,HBN,Sex,Sr_Code,HBN_Flag'  */  SET @strTableWithOldAnimalIds = 'TelReg_Old..tblAllAnimals'  SET @strTableWithNewAnimalIds = 'TelReg..tblAllAnimals'    DECLARE\t@strTableName SYSNAME  DECLARE @strSQL nVARCHAR(4000)    DECLARE csr CURSOR LOCAL FAST_FORWARD  FOR   SELECT b.Name  from syscolumns a  inner join sysobjects b  on a.id = b.id  where a.name = 'Sire_Id'    \tOPEN csr    \tFETCH NEXT FROM csr INTO   \t\t@strTableName    \tWHILE @@Fetch_Status = 0  \tBEGIN    \tSELECT @strSQL = 'ALTER TABLE ' + @strTableName + '  \tADD NewSireId INT'  \tSELECT @strSQL  \tEXECUTE sp_EXECUTESQL @strSQL    \tSELECT @strSQL = 'UPDATE ' + @strTableName + '  \tSET NewSirelId = c.Animal_Id' + '  \tFROM ' + @strTableName + ' a  \tINNER JOIN ' + @strTableWithOldAnimalIds + ' b  \tON a.Sire_Id = b.Animal_Id   \tINNER JOIN ' + @strTableWithNewAnimalIds + ' c\t  \tON b.Breed = c.Breed  \tAND b.HBN = c.HBN  \tAND b.Sex = c.Sex  \tAND b.Sr_Code = c.Sr_Code  \tAND b.HBN_Flag = c.HBN_Flag'  \tSELECT @strSQL  \tEXECUTE sp_EXECUTESQL @strSQL    \tFETCH NEXT FROM csr INTO   \t\t@strTableName    \tEND    CLOSE csr  DEALLOCATE csr",
         "4": "997"
