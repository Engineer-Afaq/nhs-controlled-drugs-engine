   "source": [
    "df = df_all\n",
    "\n",
    "# --- UNIDENTIFIED: false/true -> N/Y ---\n",
    "# Handles boolean, \"true\"/\"false\", \"1\"/\"0\", \"Y\"/\"N\" etc.\n",
    "if \"UNIDENTIFIED\" in df.columns:\n",
    "    df = df.withColumn(\n",
    "        \"UNIDENTIFIED\",\n",
    "        F.when(F.col(\"UNIDENTIFIED\").isNull(), F.lit(None).cast(\"string\"))\n",
    "         .when(F.col(\"UNIDENTIFIED\").cast(\"string\").isin(\"true\", \"True\", \"TRUE\", \"1\", \"Y\", \"y\"), F.lit(\"Y\"))\n",
    "         .when(F.col(\"UNIDENTIFIED\").cast(\"string\").isin(\"false\", \"False\", \"FALSE\", \"0\", \"N\", \"n\"), F.lit(\"N\"))\n",
    "         .otherwise(F.col(\"UNIDENTIFIED\").cast(\"string\"))  # keep unexpected values visible\n",
    "    )\n",
    "\n",
    "# --- Integer-like columns ---\n",
    "for c in [\"YEAR_MONTH\", \"QUANTITY\", \"ITEMS\", \"TOTAL_QUANTITY\", \"SNOMED_CODE\"]:\n",
    "    if c in df.columns:\n",
    "        df = df.withColumn(c, to_bigint(F.col(c)))\n",
    "\n",
    "# --- Decimal columns ---\n",
    "# ADQ_USAGE often needs more precision than money\n",
    "if \"ADQ_USAGE\" in df.columns:\n",
    "    df = df.withColumn(\"ADQ_USAGE\", to_decimal(F.col(\"ADQ_USAGE\"), precision=18, scale=4))\n",
    "\n",
    "# NIC & ACTUAL_COST are usually currency-like\n",
    "for c in [\"NIC\", \"ACTUAL_COST\"]:\n",
    "    if c in df.columns:\n",
    "        df = df.withColumn(c, to_decimal(F.col(c), precision=18, scale=2))"
   ]
  },
