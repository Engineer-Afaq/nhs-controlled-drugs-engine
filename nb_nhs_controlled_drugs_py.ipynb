    "# Reuse connections (faster than creating a new connection per request)\n",
    "session = requests.Session()\n",
    "session.headers.update({\"User-Agent\": \"fabric-notebook/1.0\"})\n",
    "\n",
    "def ym_range(start_ym: int, end_ym: int) -> List[int]:\n",
    "    \"\"\"Inclusive YYYYMM range.\"\"\"\n",
    "    y, m = divmod(start_ym, 100)\n",
    "    end_y, end_m = divmod(end_ym, 100)\n",
    "    out = []\n",
    "    while (y < end_y) or (y == end_y and m <= end_m):\n",
    "        out.append(y * 100 + m)\n",
    "        m += 1\n",
    "        if m == 13:\n",
    "            y += 1\n",
    "            m = 1\n",
    "    return out\n",
    "\n",
    "def filter_field_for_ym(ym: int) -> str:\n",
    "    # per your observation\n",
    "    return \"BNF_CHEMICAL_SUBSTANCE\" if ym <= 202502 else \"BNF_CHEMICAL_SUBSTANCE_CODE\"\n",
    "\n",
    "def http_get_json(url: str, params: dict, timeout: int = 180, retries: int = 6, backoff: float = 1.7) -> dict:\n",
    "    \"\"\"\n",
    "    Robust GET with retry (handles transient errors / rate limiting).\n",
    "    \"\"\"\n",
    "    last_err = None\n",
    "    for attempt in range(1, retries + 1):\n",
    "        try:\n",
    "            r = session.get(url, params=params, timeout=timeout)\n",
    "\n",
    "            # If rate-limited, wait and retry\n",
    "            if r.status_code in (429, 502, 503, 504):\n",
    "                time.sleep(backoff ** attempt)\n",
    "                continue\n",
    "\n",
    "            r.raise_for_status()\n",
    "            payload = r.json()\n",
    "\n",
    "            if not payload.get(\"success\", False):\n",
    "                raise RuntimeError(f\"CKAN success=false: {payload}\")\n",
    "\n",
    "            return payload\n",
    "\n",
    "        except Exception as e:\n",
    "            last_err = e\n",
    "            time.sleep(backoff ** attempt)\n",
    "\n",
    "    raise last_err\n",
    "\n",
    "RESOURCE_IDS = [f\"EPD_SNOMED_{ym}\" for ym in ym_range(START_YM, END_YM)]\n",
    "print(f\"Will load {len(RESOURCE_IDS)} resources: {RESOURCE_IDS[:3]} ... {RESOURCE_IDS[-3:]}\")\n"
   ]
