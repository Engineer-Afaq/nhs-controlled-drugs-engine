    "def make_unique_columns(df):\n",
    "    \"\"\"\n",
    "    If any duplicate column names exist, rename later duplicates with __dupN suffix.\n",
    "    Prevents [AMBIGUOUS_REFERENCE] errors.\n",
    "    \"\"\"\n",
    "    cols = df.columns\n",
    "    seen = {}\n",
    "    new_cols = []\n",
    "\n",
    "    for c in cols:\n",
    "        if c not in seen:\n",
    "            seen[c] = 0\n",
    "            new_cols.append(c)\n",
    "        else:\n",
    "            seen[c] += 1\n",
    "            new_cols.append(f\"{c}__dup{seen[c]}\")\n",
    "\n",
    "    if new_cols != cols:\n",
    "        df = df.toDF(*new_cols)\n",
    "    return df\n",
    "\n",
    "def apply_renames_safely(df, rename_map: Dict[str, str]):\n",
    "    \"\"\"\n",
    "    Rename columns without ever creating duplicates.\n",
    "    If target already exists, keep target and rename source to source__old (so no data loss).\n",
    "    \"\"\"\n",
    "    for old_name, new_name in rename_map.items():\n",
    "        if old_name in df.columns and new_name != old_name:\n",
    "            if new_name in df.columns:\n",
    "                df = df.withColumnRenamed(old_name, f\"{old_name}__old\")\n",
    "            else:\n",
    "                df = df.withColumnRenamed(old_name, new_name)\n",
    "\n",
    "    return make_unique_columns(df)"
   ]
  },
