         "3": "CREATE PROCEDURE dbo.uspCalculateAnnualSummaryFor1StopSplitHerd  \t@HerdID smallint,  \t@SocietyId smallint,  \t@YearNo smallint  -- 10/02/2004 J Wall, Set Qualifying=NQ if DEH > Calving Date  -- 30/10/2003, J Wall v1, Set 4 year filters on Calving age and interval to ignore ridiculous record (e.g. DOB = 01/05/1900)  -- 23/10/2003 J Wall, Don't write the data to Storm as we run the reports on chiefmark  -- 22/10/2003 J Wall, rewrite to incorporate latest changes,  -- 07/07/2003 J Wall, Mirror procedure of storm.milkrecording.uspCalculateAnnualSummaryData  --  extract 1-stop data and add to Storm tables for reporting  -- nb. 1Stop herds have a HerdId < 1000  -- Input @YearNo  2002 = 1st Oct 2001 to 30 Sep 2002  -- All lactations are selected where  -- There is a FatKG305  -- and  -- The lactation past 305 in the date range  -- The lactation ended in the date range    AS  DECLARE\t@xmdstr char(100)  DECLARE @intRC int  declare @startdate as smalldatetime  declare @Enddate as smalldatetime  select @startdate= CONVERT(smalldatetime, cast(@YearNo-1 as char(4)) + '-10-01', 102)  select @Enddate= CONVERT(smalldatetime, cast(@YearNo as char(4)) + '-10-01', 102)      -- write selected lactations to calculatedAnnualSummaryAnimalDetails  -- 2) are Qualifying  -- 2) open and past 305 days or closed  --- 3)  305 or enddate in the date range  /**/  truncate table CalcAnnSummSplitHerdAnimalDetails     INSERT INTO CalcAnnSummSplitHerdAnimalDetails  \t(YearEnding,  \tHerdId,   \tMrAnimalId,   \tLactationNo,   \tCalvingDate,   \tEndDate305,   \tYield305,   \tFatKg305,   \tProteinKg305,   \tCombinedFatProtein305,   \tDaysInMilk305,  \tLactationGroup,  \tAverageCellCount305,  \tProdIndex,  \tCalvingInterval,  \tPedigreeAnimalId,  \tEndDate,   \tYield,   \tFatKg,   \tProteinKg,   \tCombinedFatProtein,   \tDaysInMilk,  \tAverageCellCount,  \tQualifying,  \tBreed,  \tintEvaluationGroup,  \tQualifiedInPreviousYear,  \tAverageCalvingAge  )  SELECT  \t@YearNo,   \tl.HerdId,   \tl.AMSReference,   \tl.LactationNo,   \tl.CalvingDate,   \tDATEADD(day, lt.DaysInMilk305, l.CalvingDate) AS EndDate305,   \tlt.Yield305,   \tlt.FatKg305,   \tlt.ProteinKg305,   \tlt.FatKg305 + lt.ProteinKg305 AS CombinedFatProtein305,   \tlt.DaysInMilk305,  \tcase  \t\twhen l.LactationNo < 6 then cast(l.LactationNo as char(3))  \t\telse '6+'  \tend,  \tlt.AverageCellCount305,  \tlt.ProdIndex,  \tcase  \t\twhen l.LactationNo>1 then lt.CalvingInterval  \t\telse null  \tend,  \ta.HUKIReference,  \tDATEADD(day, lt.DaysInMilk, l.CalvingDate) AS EndDate,   \tlt.Yield,   \tlt.FatKg,   \tlt.ProteinKg,   \tlt.FatKg + lt.ProteinKg AS CombinedFatProtein,   \tlt.DaysInMilk,  \tlt.AverageCellCount,  \tcase  \t\twhen a.DateEnteredHerd is null then lt.Qualifying  \t\twhen a.DateEnteredHerd < dateadd(day,30,l.CalvingDate) then lt.Qualifying  \t\telse 0  \t\tend,  \tisnull(a.Breed,'01'),  \tNULL,\t--intEvaluationGroup,  \tcase  \t\twhen (isnull(lt.Qualifying,0) = 1   \t\tAND (DATEADD(day, lt.DaysInMilk305, l.CalvingDate) < @startdate)   \t\tAND (DATEADD(day, lt.DaysInMilk, l.CalvingDate) >= @startdate)   \t\tAND (DATEADD(day, lt.DaysInMilk, l.CalvingDate) < @Enddate)) then 'Y'  \t\telse 'N'  \t\tend,  \tCalvingAge  FROM  tblAMSLactations l  INNER Join tblAMSLactationtTotals lt  \ton l.PID=lt.PID  \tand l.HerdCode=lt.HerdCode  \tand l.AMSReference = lt.AMSReference  \tand l.LactationNo = lt.LactationNo  LEFT OUTER JOIN tblAMSAnimals a  \tON l.HerdId = a.HerdId  \tand l.AMSReference = a.AMSReference  Inner JOIN tlkpBreedCodes   \ton tlkpBreedCodes.breed = a.Breed  WHERE (\t  \t\t\t(isnull(lt.Qualifying,0) = 1   \t\t\t\tAND (DATEADD(day, lt.DaysInMilk305, l.CalvingDate) >= @startdate)   \t\t\t\tAND (DATEADD(day, lt.DaysInMilk305, l.CalvingDate) < @Enddate)   \t\t\t)  \t\tor  \t\t\t(isnull(lt.Qualifying,0) = 0  \t\t\t\tand (l.EndDate >= @startdate)   \t\t\t\tAND (l.EndDate < @Enddate)  \t\t\t)  \t\tor\t-- qualified previous year and still  milking this year  \t\t\t(isnull(lt.Qualifying,0) = 1   \t\t\t\tAND (DATEADD(day, lt.DaysInMilk305, l.CalvingDate) < @startdate)   \t\t\t\tAND (DATEADD(day, lt.DaysInMilk, l.CalvingDate) >= @startdate)   \t\t\t\tAND (DATEADD(day, lt.DaysInMilk, l.CalvingDate) < @Enddate)   \t\t\t)  \t)  and a.herdId=@HerdId  and tlkpBreedCodes.Society_Id=@SocietyId  -- try to match Non peds  Update sa set  sa.PedigreeAnimalId = pa.Animal_ID  FROM   CalcAnnSummSplitHerdAnimalDetails sa   INNER JOIN tblAMSAnimals a   \tON sa.HerdId = a.HerdID   \tAND sa.MrAnimalId = a.AMSReference   INNER JOIN tblAllAnimals pa   \tON a.breed = pa.Breed   \tAND a.hbn = pa.HBN  WHERE     (sa.PedigreeAnimalId IS NULL)\t\t  Update sa set  sa.PedigreeAnimalId = pa.Animal_ID  FROM  CalcAnnSummSplitHerdAnimalDetails sa   INNER JOIN tblAMSAnimals a   \tON sa.HerdId = a.HerdID   \tAND sa.MrAnimalId = a.AMSReference   LEFT OUTER JOIN tblAllAnimals pa   \tON a.eartag = pa.Ear_Mark  WHERE  (sa.PedigreeAnimalId IS NULL)    -- set the evaluation group and remove any 0's from cell count and calving interval   -- (so they do not effect the averages)  UPDATE CalcAnnSummSplitHerdAnimalDetails  SET   \tintEvaluationGroup =   \t\tCASE   \t\t\tWHEN b.intEvaluationGroup IS NULL THEN 1  \t\t\tELSE b.intEvaluationGroup  \t\tEND,  \tAverageCellCount305 =   \t\tCASE   \t\t\tWHEN isnull(AverageCellCount305, 0) = 0 THEN NULL   \t\t\tELSE AverageCellCount305   \t\tEND,   \tAverageCellCount =   \t\tCASE   \t\t\tWHEN isnull(AverageCellCount, 0) = 0 THEN NULL   \t\t\tELSE AverageCellCount   \t\tEND,   \tCalvingInterval =   \t\tCASE   \t\t\tWHEN isnull(CalvingInterval, 0) = 0 THEN NULL   \t\t\tWHEN isnull(CalvingInterval, 0) > 1461 THEN NULL -- ignore in totals if interval > 48 months  \t\t\tELSE CalvingInterval   \t\tEND,  \tAverageCalvingAge =   \t\tCASE   \t\t\tWHEN isnull(AverageCalvingAge, 0) = 0 THEN NULL   \t\t\tWHEN isnull(AverageCalvingAge, 0) > 48 THEN NULL -- ignore in totals if 1st calving after 48 months  \t\t\tELSE AverageCalvingAge   \t\tEND  FROM CalcAnnSummSplitHerdAnimalDetails AS a  LEFT OUTER JOIN WebData.dbo.tlkpBreedToEvaluationGroup AS b  ON\tb.strBreedCode = a.Breed    -- Load the PIN/PLI  Update sa  set Pin = p.intPin,   \tsa.PLI = p.intPLI,  \tsa.PTARlb = p.intRlb,  \tsa.PTAMilk = p.intMilk,  \tsa.PTABfatPc = p.sngBfatPc,  \tsa.PTABfatKg = p.sngBfatKg,  \tsa.PTAProtPc = p.sngProtPc,  \tsa.PTAProtKg = p.sngProtKg  FROM  CalcAnnSummSplitHerdAnimalDetails sa  INNER JOIN WebData.dbo.tblPTA p  \tON sa.PedigreeAnimalId = p.Animal_ID  \tAND sa.intEvaluationGroup = p.intEvaluationGroup  \tAND p.strPublishStatus= 'X'    --   Produce the Herd Averages by Lactation Group  truncate table  CalcAnnSummSplitHerdHerdDetails     INSERT INTO CalcAnnSummSplitHerdHerdDetails  \t(YearEnding,  \tHerdId,  \tLactationGroup,   \tNoOfAnimalsQualifying,   \tNoOfAnimalsNonQualifying,   \tTotalCombinedFatProtein,   \tAverageCombinedFatProtein,  \tTotalYield,  \tAverageYield,  \tTotalFatKg,  \tAverageFatKg,  \tAverageFatPc,  \tTotalProtKg,  \tAverageProtKg,  \tAverageProtPc,  \tAverageCellCount,  \tAverageProdIndex,  \tAveragePIN,  \tAveragePLI,  \tAverageCalvingInterval,  \tAverageDIM,  \tAverageCellCountNatural,  \tAverageCalvingAge)  SELECT   \t@YearNo,  \tHerdId,  \tLactationGroup,   \tCOUNT(*) AS NoOfAnimalsQualifying,  \t0,   \tSUM(CombinedFatProtein305) AS TotalCombinedFatProtein,   \tAVG(CombinedFatProtein305) AS AverageCombinedFatProtein,  \tSUM(Yield305) AS TotalYield,   \tAVG(Yield305) AS AverageYield,  \tSUM(FatKg305) AS TotalFatKg,   \tAVG(FatKg305) AS AverageFatKg,  \t100.0 * Sum(FatKg305) / sum(Yield305) AS AverageFatPc,  \tSUM(ProteinKg305) AS TotalProtKg,   \tAVG(ProteinKg305) AS AverageProtKg,  \t100.0 * SUM(ProteinKg305) / Sum(Yield305) AS AverageProtPc,  \tAVG(AverageCellCount305*1.0) AS AverageCellCount,  \tAVG(ProdIndex*1.0) AS AverageProdIndex,  \tAVG(Pin*1.0) AS AveragePIN,  \tAVG([PLI]*1.0) AS AveragePLI,  \tAVG(CalvingInterval*1.0) AS AverageCalvingInterval,  \tAVG(DaysInMilk305*1.0) AS AverageDIM,  \tAVG(AverageCellCount*1.0) AS AverageCellCountNatural,  \tAVG(AverageCalvingAge*1.0) AS AverageCalvingAge  FROM  CalcAnnSummSplitHerdAnimalDetails  where YearEnding=@YearNo  and Qualifying=1  and isnull(Yield305,0)>0  and QualifiedInPreviousYear='N'  GROUP BY HerdId,LactationGroup    --Add the Herd totals  INSERT INTO CalcAnnSummSplitHerdHerdDetails  \t(YearEnding,  \tHerdId,  \tLactationGroup,   \tNoOfAnimalsQualifying,   \tNoOfAnimalsNonQualifying,   \tTotalCombinedFatProtein,   \tAverageCombinedFatProtein,  \tTotalYield,  \tAverageYield,  \tTotalFatKg,  \tAverageFatKg,  \tAverageFatPc,  \tTotalProtKg,  \tAverageProtKg,  \tAverageProtPc,  \tAverageCellCount,  \tAverageProdIndex,  \tAveragePIN,  \tAveragePLI,  \tAverageCalvingInterval,  \tAverageDIM,  \tAverageCellCountNatural,  \tAverageCalvingAge)  SELECT   \t@YearNo,  \tHerdId,  \t'All' as LactationGroup,   \tCOUNT(*) AS NoOfAnimalsQualifying,  \t0,   \tSUM(CombinedFatProtein305) AS TotalCombinedFatProtein,   \tAVG(CombinedFatProtein305) AS AverageCombinedFatProtein,  \tSUM(Yield305) AS TotalYield,   \tAVG(Yield305) AS AverageYield,  \tSUM(FatKg305) AS TotalFatKg,   \tAVG(FatKg305) AS AverageFatKg,  \t--AVG(100 * FatKg305 / Yield305) AS AverageFatPc,  \t100.0 * Sum(FatKg305) / sum(Yield305) AS AverageFatPc,  \tSUM(ProteinKg305) AS TotalProtKg,   \tAVG(ProteinKg305) AS AverageProtKg,  \t100.0 * SUM(ProteinKg305) / Sum(Yield305) AS AverageProtPc,  \tAVG(AverageCellCount305*1.0) AS AverageCellCount,  \tAVG(ProdIndex*1.0) AS AverageProdIndex,  \tAVG(Pin*1.0) AS AveragePIN,  \tAVG([PLI]*1.0) AS AveragePLI,  \tAVG(CalvingInterval*1.0) AS AverageCalvingInterval,  \tAVG(DaysInMilk305*1.0) AS AverageDIM,  \tAVG(AverageCellCount*1.0) AS AverageCellCountNatural,  \tAVG(AverageCalvingAge*1.0) AS AverageCalvingAge  FROM  CalcAnnSummSplitHerdAnimalDetails  where YearEnding=@YearNo  and Qualifying=1  and isnull(Yield305,0)>0  and QualifiedInPreviousYear='N'  GROUP BY HerdId      ---  calculate the non qualifiers  --count by Herd/Lactation Group  select   \tHerdId,  \tLactationGroup,   \tCOUNT(*) AS NoOfAnimalsNonQualifying  Into #nonQualifierTotals  FROM  CalcAnnSummSplitHerdAnimalDetails  WHERE (Qualifying <> 1)   and YearEnding=@YearNo  GROUP BY HerdId,LactationGroup    --Add the Herd totals  INSERT INTO #nonQualifierTotals  \t(HerdId,  \tLactationGroup,   \tNoOfAnimalsNonQualifying)  select   \tHerdId,  \t'All',   \tCOUNT(*)   FROM  CalcAnnSummSplitHerdAnimalDetails  WHERE (Qualifying <> 1)   and YearEnding=@YearNo  GROUP BY HerdId    -- Update the herd summary  Update CalcAnnSummSplitHerdHerdDetails set  \tNoOfAnimalsNonQualifying=#nonQualifierTotals.NoOfAnimalsNonQualifying  from #nonQualifierTotals  inner join CalcAnnSummSplitHerdHerdDetails  \ton #nonQualifierTotals.HerdId = CalcAnnSummSplitHerdHerdDetails.HerdId  \tand #nonQualifierTotals.LactationGroup = CalcAnnSummSplitHerdHerdDetails.LactationGroup  \tand YearEnding = @YearNo    -- Calculate predominant society  --exec uspCalculateAnnualSummaryPredSocietyFor1Stop\t@YearNo    uspCalculateAnnualSummaryData_Exit:    RETURN",
