    "def datastore_fields(resource_id: str) -> List[str]:\n",
    "    \"\"\"\n",
    "    NHSBSA returns 404 for datastore_info, so we use datastore_search metadata instead.\n",
    "    limit=1 ensures 'fields' are returned.\n",
    "    \"\"\"\n",
    "    payload = http_get_json(\n",
    "        DATASTORE_SEARCH,\n",
    "        params={\"resource_id\": resource_id, \"limit\": 1, \"offset\": 0},\n",
    "        timeout=180\n",
    "    )\n",
    "    ids = [f[\"id\"] for f in payload[\"result\"][\"fields\"]]\n",
    "    if DROP_INTERNAL_ID:\n",
    "        ids = [c for c in ids if c != \"_id\"]\n",
    "    return ids\n",
    "\n",
    "CANONICAL_FIELDS = datastore_fields(CANONICAL_RESOURCE)\n",
    "\n",
    "print(f\"Canonical resource: {CANONICAL_RESOURCE}\")\n",
    "print(f\"Canonical field count: {len(CANONICAL_FIELDS)}\")\n",
    "print(\"First 20 canonical fields:\", CANONICAL_FIELDS[:20])"
   ]
