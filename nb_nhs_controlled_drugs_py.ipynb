         "0": "MilkRecording",
         "1": "dbo",
         "2": "uspHtListRecordingsWithTestDate",
         "3": "CREATE PROCEDURE [dbo].[uspHtListRecordingsWithTestDate]  --DROP TABLE #tmp    @Herdid INT, -- = dbo.cisherdid('10346'),  @Disease VARCHAR(30) --= 'Johnes'  as  \tSELECT  \t\tLoadID = Max(htr.LoadID)  \t\t,TestDate = CONVERT(varchar(15), ISNULL(mr.RecordingDate, LabDate), 106)  \t\t,DisplayDate = CONVERT(varchar(15), ISNULL(mr.RecordingDate, LabDate), 106) + ' - CIS' + @Disease + CAST(Max(htr.MrLoadId) AS varchar(15))  \tINTO  \t\t#tmp  \tFROM  \t\ttblHTResults htr  \t\tLEFT OUTER JOIN dbo.tblMilkRecordings mr  \t\t\tON htr.MrLoadId = mr.LoadID\t\t\t  \tWHERE  \t\thtr.HerdId = @Herdid  \t\tand case when @Disease = 'Johnes' then htr.JohnesResult  \t\t\t\t when @Disease = 'BVDAntibody' then htr.BVDResult  \t\t\t\t when @Disease = 'BVDAntigen' then BVDAntigenResult  \t\t\t\t when @Disease = 'IBR' then htr.IBRResult  \t\t\t\t when @Disease = 'Neospora' then htr.NeosporaResult  \t\t\t\t when @Disease = 'IBRgEAB' then htr.IBRgEABResult  \t\t\t\t when @Disease = 'Fluke' then htr.FlukeResult  \t\t\t\t when @Disease = 'Schmallenberg' then htr.SchmallenbergResult  \t\t\t\t when @Disease = 'PregCheck' then htr.PregnancyTestingResult  \t\t\t\t when @Disease = 'Leptospirosis' then htr.LeptospirosisResult  \t\t\tEND is not null     \t\tGROUP BY  \t\tCONVERT(varchar(15), ISNULL(mr.RecordingDate, LabDate), 106)    \t\tselect * from #tmp  \t\tORDER BY  \t\tCAST(TestDate AS DATETIME) DESC  \t\t,LoadID DESC  RETURN     GRANT EXECUTE ON [dbo].[uspHtListRecordingsWithTestDate] TO MilkRecordingRole",
         "4": "997"
        }
