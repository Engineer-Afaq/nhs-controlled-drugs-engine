         "2": "uspCisLabsMergeUnmatchedBarcodes",
         "3": "    CREATE PROCEDURE  [dbo].[uspCisLabsMergeUnmatchedBarcodes]  \t@loadid INT,  \t@AddedBy VARCHAR(50),  \t@LabBarcode VARCHAR(25),  \t@NoLabBarcodesAdded int  \t-- 08/03/2013 J Wall, replaced LabBarcodeLoggingStarted/Ended fields with DateSamplesArrivedAtLab  \t-- 27/06/2012 J Wall,  add any unmtached barcodes  \t--                                 called from CisLabWebService.Labs.SaveChanges  AS  \tdeclare @LBMRecId int  \t-- First Time procedure is called for a batch add the header record  \t  \tIF NOT EXISTS(Select * FROM CisLabBatchHeader WHERE BatchLabBarCodeLoadId =@loadid)  \t\t\tINSERT INTO dbo.CisLabBatchHeader   \t\t\t\t\t( BatchMrLoadId ,  \t\t\t\t\t  BatchLabBarCodeLoadId ,  \t\t\t\t\t  BatchComments ,  \t\t\t\t\t  CommentsAddedBy,  \t\t\t\t\t  DateSamplesArrivedAtLab  \t\t\t\t\t)  \t\t\tVALUES \t\t\t\t\t  \t\t\t\t\t( null ,  \t\t\t\t\t  @loadid ,  \t\t\t\t\t  null ,  \t\t\t\t\t  NULL,  \t\t\t\t\t  GETDATE()   \t\t\t\t\t)    \t  \t  \tselect @LBMRecId= LBMRecId  \tFROM dbo.CisLabBottleManagement  \tWHERE BarCode=@LabBarcode  \tIF @LBMRecId IS NOT NULL  \t\tBEGIN  \t\t\t--Update any matched barcodes  \t\t\tUPDATE CisLabBottleManagement SET  \t\t\t\tDateLabBarCodeUploaded=GETDATE(),  \t\t\t\tLabBarCodeAddedBy=@AddedBy\t,  \t\t\t\tLabBarCodeLoadId=@loadid\t  \t\t\tWHERE LBMRecId =@LBMRecId  \t\tEND  \tELSE\t  \t\tBEGIN  \t\t\t--Add any unmatched barcodes  \t\t\tINSERT INTO dbo.CisLabBottleManagement  \t\t\t\t( BarCode ,  \t\t\t\t  BoxBarCode ,  \t\t\t\t  DateLabBarCodeUploaded ,  \t\t\t\t  LabBarCodeAddedBy,  \t\t\t\t  LabBarCodeLoadId )  \t\t\tSELECT    \t\t\t\t@LabBarcode ,  \t\t\t\t'' ,  \t\t\t\tGETDATE(),  \t\t\t\t@AddedBy,  \t\t\t\t@loadid  \t\tEND      RETURN",
