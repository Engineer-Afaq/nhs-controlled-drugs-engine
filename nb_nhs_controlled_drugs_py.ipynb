    "def clean_number_str(col):\n",
    "    \"\"\"\n",
    "    Turns common numeric text forms into something castable:\n",
    "    - trims\n",
    "    - removes commas and spaces\n",
    "    - keeps digits, minus, dot\n",
    "    \"\"\"\n",
    "    return F.regexp_replace(F.trim(col.cast(\"string\")), r\"[,\\s]\", \"\")\n",
    "\n",
    "def to_bigint(col):\n",
    "    return clean_number_str(col).cast(\"bigint\")\n",
    "\n",
    "def to_decimal(col, precision=18, scale=2):\n",
    "    # remove anything that's not digit, minus, dot\n",
    "    cleaned = F.regexp_replace(F.trim(col.cast(\"string\")), r\"[^0-9\\.\\-]\", \"\")\n",
    "    return cleaned.cast(T.DecimalType(precision, scale))\n"
   ]
  },
