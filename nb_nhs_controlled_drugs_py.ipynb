         "0": "Telreg",
         "1": "dbo",
         "2": "spu_MatchAMSHUKICodes2",
         "3": "    CREATE Procedure [dbo].[spu_MatchAMSHUKICodes2]  \t\t\t@HerdID integer  -- 14/11/2003 - v1 J Wall,Min EarTag length=6  -- 31/10/2003 - v1 J Wall,try to match on eartags formatted as UK prefix suffix (convert to prefix/suffix)  -- 27/10/2003 - v1 J Wall,Update any German Sires and service sires to the new HBN  -- 29/08/2003 - v1 J Wall,Match Non Peds on EarTag  -- 20/08/2003 - v1 J Wall,Don't match Animal Name if blank  -- 24/06/2002 - v1 J Wall,Added Animal Name match  -- 14/06/2002 - v1 J Wall,*******************************************************************************  -- 14/06/2002 - v1 J Wall,*BcmsEartag matches commented out until the field is populated by Paul next week**  -- 14/06/2002 - v1 J Wall,*******************************************************************************  -- 14/06/2002 - v1 J Wall, Use Temp Table to improve performance of eartag matchs  -- 27/05/2002 - v1 J Wall, Don't match eartags of less than 8 characters  -- 12/04/2002 - v1 J Wall, Add match on AMSRef received from 1Stop Calf Registration  -- 13/03/2002 - v1 J Wall, Only match on OrigSource=1 (Ingres records) so that we don't use some of the duff duplicate records in tblallanimals  -- 11/01/2002 - v1 J Wall, Check Sex of matched animals  -- 28/11/2001 - v1 J Wall, Merge females & Males into tblAllAnimals (Changed)  -- 04/05/2001 - v1 J Wall, set dam sire id as per pedigree record  -- 30/05/2001 - v1 J Wall, explicit ref to eartag indexes added since not used after updating to SQLServer 7 SP3   -- 03/04/2001 - v1 J Wall, Set Merged Herdbbok fields to the best data (Breed society values if matched, otherwise farmers values)   -- 05/12/2000 - v1 J Wall, If animal matched set the Sire and DoB values to the HUKI data rather than farmer data   -- 28/04/2000 - v1 J Wall, Try to match AMS animals with HUKI animals for one AMS Herd  As  declare @SocietyID int  declare @prefix varchar(40)    --reset any german bulls  UPDATE  a SET  \ta.Sirebreed = g.newbreed,  \ta.Sirehbn = g.newhbn,  \ta.SireHukiReference = g.NewAnimalId  FROM  tblAMSAnimals a   INNER JOIN tlkpGermanHBNChange g   \tON a.Sirebreed = g.oldbreed   \tAND a.Sirehbn = g.oldhbn  WHERE     (a.HerdID = @HerdID)  -- reset German Service Sires  update l set       \tl.ServiceSireBreed = g.newbreed,   \tl.ServiceSireHBN = g.newhbn,   \tl.ServiceSireHukiRef = g.NewAnimalId  FROM tlkpGermanHBNChange g   INNER JOIN  tblAMSlactations l   \tON g.oldbreed = l.ServiceSireBreed   \tAND g.oldhbn = l.ServiceSireHBN  WHERE     (l.HerdID = @HerdID)  -- 05) get herd headers  SELECT   \t@SocietyID=SocietyID,   \t@prefix=prefix  FROM   \ttblAMSHerds  WHERE   \t(HerdID = @HerdID)    -- 10)Write data to temp table to improve efficiency  SELECT *  INTO #tmpAMSAnimals  FROM tblAMSAnimals  WHERE (tblAMSAnimals.HerdID = @HerdID)    -- 15) Clear down HUKIReference values and default HBN values to farmers  UPDATE   \t#tmpAMSAnimals  SET   \tHUKIReference=null,  \tDamHUKIReference=null,  \tSireHUKIReference=null,  \tMergedbreed = breed,   \tMergedhbn = hbn      -- Try to match records, NB.  steps are in descending order of quality   -- so later matches should not overwrite better earlier matches    --20) Try to match on AMSRef loaded as part of the 1Stop registration  Update  \t#tmpAMSAnimals  set   \tHUKIReference=tblAllAnimals.Animal_ID,  \tDateOfBirth=tblAllAnimals.DateOfBirth,  \tMergedbreed = tblAllAnimals.breed,   \tMergedhbn = tblAllAnimals.hbn,  \tMergedhbn_flag = tblAllAnimals.hbn_flag,  \tMergedsr_Code = tblAllAnimals.sr_Code  FROM   \t#tmpAMSAnimals   INNER JOIN      tblAllAnimals   ON   \ttblAllAnimals.Society_ID=@SocietyID  AND   \ttblAllAnimals.Herd_prefix=@prefix  And  \ttblAllAnimals.AMSReference=#tmpAMSAnimals.AMSReference  WHERE       (tblAllAnimals.Animal_ID IS NOT NULL)  AND  \t(tblAllAnimals.Sex ='F')  AND  \t(tblAllAnimals.origsource =1)    -- 30) Try to Match animal on HBN  Update  \t#tmpAMSAnimals  set   \tHUKIReference=tblAllAnimals.Animal_ID,  \tDateOfBirth=tblAllAnimals.DateOfBirth,  \tMergedbreed = tblAllAnimals.breed,   \tMergedhbn = tblAllAnimals.hbn,  \tMergedhbn_flag = tblAllAnimals.hbn_flag,  \tMergedsr_Code = tblAllAnimals.sr_Code  FROM   \t#tmpAMSAnimals   INNER JOIN      tblAllAnimals   ON       #tmpAMSAnimals.breed = tblAllAnimals.breed   AND       #tmpAMSAnimals.hbn = tblAllAnimals.hbn  WHERE       (tblAllAnimals.Animal_ID IS NOT NULL)  AND      (#tmpAMSAnimals.HUKIReference is null)  AND  \t(tblAllAnimals.Sex ='F')  AND  \t(tblAllAnimals.origsource =1)        -- 35) Try to Match animal on Name  Update  \t#tmpAMSAnimals  set   \tHUKIReference=tblAllAnimals.Animal_ID,  \tDateOfBirth=tblAllAnimals.DateOfBirth,  \tMergedbreed = tblAllAnimals.breed,   \tMergedhbn = tblAllAnimals.hbn,  \tMergedhbn_flag = tblAllAnimals.hbn_flag,  \tMergedsr_Code = tblAllAnimals.sr_Code  FROM   \t#tmpAMSAnimals   INNER JOIN      tblAllAnimals   ON       #tmpAMSAnimals.fullname = tblAllAnimals.Prefix + ' ' + tblAllAnimals.animal_name + ' ' + Serial_No  WHERE       (tblAllAnimals.Animal_ID IS NOT NULL)  AND   \t(tblAllAnimals.herd_prefix =@prefix)  AND  \t(tblAllAnimals.Society_ID =@SocietyID)  AND      (#tmpAMSAnimals.HUKIReference is null)  AND\t  \t(rtrim(Isnull(#tmpAMSAnimals.fullname,''))<>'')  AND  \t(tblAllAnimals.Sex ='F')  AND  \t(tblAllAnimals.origsource =1)      -- try to match any non peds on eartag  Update  \t#tmpAMSAnimals  set   \tHUKIReference=a.Animal_ID  FROM #tmpAMSAnimals AmsA   INNER JOIN tblAllAnimals A   \tON AmsA.eartag = A.Ear_Mark  WHERE (AmsA.HUKIReference IS NULL)   and len(RTRIM(ltrim((ISNULL(AmsA.eartag, '')))))>6  AND (A.Society_ID = 9)    -- try to match any non peds on eartag  Update  \t#tmpAMSAnimals  set   \tHUKIReference=a.Animal_ID  FROM #tmpAMSAnimals AmsA   INNER JOIN tblAllAnimals A   \tON A.Ear_Mark =   \tcase  \twhen left(AmsA.eartag,2) IN('UK','XI') then replace(ltrim(rtrim(substring(AmsA.eartag,3,99))),' ' ,'/')  \telse replace(ltrim(rtrim(AmsA.eartag)),' ' ,'/')  \tend  WHERE (AmsA.HUKIReference IS NULL)   and len(RTRIM(ltrim((ISNULL(AmsA.eartag, '')))))>6      -- 40) Try to Match  on Ingres earmark  /*  Update  \t#tmpAMSAnimals  set   \tHUKIReference=tblAllAnimals.Animal_ID,  \tDateOfBirth=tblAllAnimals.DateOfBirth,  \tMergedbreed = tblAllAnimals.breed,   \tMergedhbn = tblAllAnimals.hbn,  \tMergedhbn_flag = tblAllAnimals.hbn_flag,  \tMergedsr_Code = tblAllAnimals.sr_Code  FROM   \t#tmpAMSAnimals   INNER JOIN  \ttblAllAnimals    ON   \t#tmpAMSAnimals.eartag = tblAllAnimals.ear_mark  WHERE   \t(#tmpAMSAnimals.HUKIReference is null)   AND       (tblAllAnimals.Animal_ID IS NOT NULL)   AND       (len(#tmpAMSAnimals.eartag)>7)\t  AND  \t(tblAllAnimals.Sex ='F')  AND  \t(tblAllAnimals.origsource =1)\t  */  -- 50) Try to Match  on BCMS eartag  /*Update  \t#tmpAMSAnimals  set   \tHUKIReference=tblAllAnimals.Animal_ID,  \tDateOfBirth=tblAllAnimals.DateOfBirth,  \tMergedbreed = tblAllAnimals.breed,   \tMergedhbn = tblAllAnimals.hbn,  \tMergedhbn_flag = tblAllAnimals.hbn_flag,  \tMergedsr_Code = tblAllAnimals.sr_Code  FROM   \t#tmpAMSAnimals   INNER JOIN  \ttblAllAnimals    ON   \t#tmpAMSAnimals.eartag = tblAllAnimals.BcmsEartag  WHERE   \t(#tmpAMSAnimals.HUKIReference is null)   AND       (tblAllAnimals.Animal_ID IS NOT NULL)  AND       (len(#tmpAMSAnimals.eartag)>7)\t  AND  \t(tblAllAnimals.Sex ='F')  AND  \t(tblAllAnimals.origsource =1)\t*/    -- 60) Try to Match  on Non Pedigree Ingres earmark  /*Update  \t#tmpAMSAnimals  set   \tHUKIReference=tblAllAnimals.Animal_ID,  \tDateOfBirth=tblAllAnimals.DateOfBirth,  \tMergedbreed = tblAllAnimals.breed,   \tMergedhbn = tblAllAnimals.hbn,  \tMergedhbn_flag = tblAllAnimals.hbn_flag,  \tMergedsr_Code = tblAllAnimals.sr_Code  FROM   \t#tmpAMSAnimals   INNER JOIN  \ttblAllAnimals    ON   \t#tmpAMSAnimals.eartag = tblAllAnimals.ear_mark  WHERE   \t(#tmpAMSAnimals.HUKIReference is null)   AND       (tblAllAnimals.Animal_ID IS NOT NULL)   AND       (len(#tmpAMSAnimals.eartag)>7)\t  AND  \t(tblAllAnimals.Sex ='F')  AND  \t(tblAllAnimals.origsource <>1)\t  */  -- 70) Try to Match  on  Non Pedigree BCMS eartag  /*Update  \t#tmpAMSAnimals  set   \tHUKIReference=tblAllAnimals.Animal_ID,  \tDateOfBirth=tblAllAnimals.DateOfBirth,  \tMergedbreed = tblAllAnimals.breed,   \tMergedhbn = tblAllAnimals.hbn,  \tMergedhbn_flag = tblAllAnimals.hbn_flag,  \tMergedsr_Code = tblAllAnimals.sr_Code  FROM   \t#tmpAMSAnimals   INNER JOIN  \ttblAllAnimals    ON   \t#tmpAMSAnimals.eartag = tblAllAnimals.BcmsEartag  WHERE   \t(#tmpAMSAnimals.HUKIReference is null)   AND       (tblAllAnimals.Animal_ID IS NOT NULL)  AND       (len(#tmpAMSAnimals.eartag)>7)\t  AND  \t(tblAllAnimals.Sex ='F')  AND  \t(tblAllAnimals.origsource <>1)\t  \t  */  -- 80) Try to Match Dam on HBN  Update  \t#tmpAMSAnimals  set   \tDamHUKIReference=tblAllAnimals.Animal_ID  FROM   \t#tmpAMSAnimals   INNER JOIN      tblAllAnimals   ON       #tmpAMSAnimals.DamHBN = tblAllAnimals.hbn   AND       #tmpAMSAnimals.DamBreed = tblAllAnimals.breed  WHERE   \t(#tmpAMSAnimals.HerdID = @HerdID)   AND       (tblAllAnimals.Animal_ID IS NOT NULL)   AND  \t(tblAllAnimals.Sex ='F')  AND  \t(tblAllAnimals.origsource =1)    -- 90) Try to Match Sire on HBN  Update  \t#tmpAMSAnimals  set   \tSireHUKIReference=tblAllAnimals.Animal_ID  FROM   \t#tmpAMSAnimals   INNER JOIN      tblAllAnimals   ON       #tmpAMSAnimals.Sirehbn = tblAllAnimals.hbn   AND       #tmpAMSAnimals.Sirebreed = tblAllAnimals.breed  WHERE   \t(#tmpAMSAnimals.HerdID = @HerdID)   AND       (tblAllAnimals.Animal_ID IS NOT NULL)   AND  \t(tblAllAnimals.Sex ='M')  AND  \t(tblAllAnimals.origsource =1)    -- 100) Try to Match Service Sire on HBN  Update  \ttblAMSLactations  set   \tServiceSireHUKIRef=tblAllAnimals.Animal_ID  FROM   \ttblAMSLactations   INNER JOIN      tblAllAnimals   ON       tblAMSLactations.ServiceSirehbn = tblAllAnimals.hbn   AND       tblAMSLactations.ServiceSirebreed = tblAllAnimals.breed  WHERE   \t(tblAMSLactations.HerdID = @HerdID)   AND       (tblAllAnimals.Animal_ID IS NOT NULL)   AND  \t(tblAllAnimals.Sex ='M')  AND  \t(tblAllAnimals.origsource =1)    -- 110) OverWrite Dam and Sire HUKIReferences with the official values  UPDATE   \t#tmpAMSAnimals  SET   \t#tmpAMSAnimals.DamHUKIReference = tblAllAnimals.Dam_ID,   \t#tmpAMSAnimals.SireHUKIReference = tblAllAnimals.Sire_ID  FROM   \t#tmpAMSAnimals   INNER JOIN     tblAllAnimals   ON      #tmpAMSAnimals.HUKIReference = tblAllAnimals.Animal_ID  WHERE   \t(#tmpAMSAnimals.HerdID = @HerdID)    -- 120) Update tblAMSAnimals with the new values  Update  \ttblAMSAnimals  set  \tHUKIReference = #tmpAMSAnimals.HUKIReference,  \tDateOfBirth =  #tmpAMSAnimals.DateOfBirth,  \tMergedbreed = #tmpAMSAnimals.Mergedbreed,  \tMergedhbn = #tmpAMSAnimals.Mergedhbn,  \tMergedhbn_flag = #tmpAMSAnimals.Mergedhbn_flag,  \tMergedsr_code = #tmpAMSAnimals.Mergedsr_code,  \tDamHUKIReference = #tmpAMSAnimals.DamHUKIReference,  \tSireHUKIReference = #tmpAMSAnimals.SireHUKIReference  FROM   \t#tmpAMSAnimals   INNER JOIN      tblAMSAnimals   ON   \t#tmpAMSAnimals.HerdID = tblAMSAnimals.HerdID   AND       #tmpAMSAnimals.AMSReference = tblAMSAnimals.AMSReference  --- 130) return a recordset of animnals with matching huki codes  SELECT   \tAMSReference,   \tHUKIReference,   \tDamHUKIReference,       SireHUKIReference  FROM   \t#tmpAMSAnimals \t  Where  \t#tmpAMSAnimals.HerdID = @HerdID  jwtemp_Exit:  return",
         "4": "7972",
         "5": "500",
         "6": "1. Stored Procedure Name: spu_MatchAMSHUKICodes2\n2. Stored Procedure Complexity: Complex\n3. Logic can be replicated in Dataverse using Power Automate: Yes\n4. Purpose: Matches AMS animals to HUKI codes and related references for a given herd, updating the HUKI/Sire/Dam data, and returns a list of animals with matched HUKI codes.\n5. Summary of stored procedure:\n- The procedure takes a HerdID and builds a working set of AMS animals for that herd in a temporary table for processing.\n- It resets certain HUKI, DamHUKIReference and Merged values to prepare for matching with external master records.\n- It then performs a series of increasingly conservative matching steps, starting with AMSReference-based matches to a master tblAllAnimals and propagating matched fields into the temporary set.\n- It proceeds to match on HBN, merging breed and HBN values, and marks HUKI references with final identifiers where possible.\n- It also attempts to match on the animal name by comparing the temporary full name with the master dataset, filtering by herd prefix and society, and only using matches that pass quality checks.\n- A series of earmark-based matching steps attempt to align eartags from AMS, Ingres, and BCMS sources, including non-pedigree variants, and update HUKI references accordingly.\n- There are steps to overwrite Dam and Sire HUKIReferences with official values, then to update the tblAMSAnimals table with the new HUKI and related fields.\n- The procedure writes a final result set that displays AMSReference, HUKIReference, DamHUKIReference and SireHUKIReference for the matched animals in the specified herd.\n- The overall aim is to consolidate animal identities across multiple data sources and produce a clean mapping of AMS records to HUKI codes.\n- The procedure uses a temporary table to improve performance and relies on multiple join paths to derive the best possible matches before final update.\n- It ends with a return of the matched recordset for the herd."
        },
