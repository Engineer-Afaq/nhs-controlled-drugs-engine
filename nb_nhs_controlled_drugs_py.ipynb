    "dfs = []\n",
    "stats = []\n",
    "\n",
    "for rid in RESOURCE_IDS:\n",
    "    try:\n",
    "        df, pages, rows = load_resource(rid, CANONICAL_FIELDS, CANONICAL_FIELDS)\n",
    "        if df is not None:\n",
    "            dfs.append(df)\n",
    "        stats.append((rid, pages, rows))\n",
    "        print(f\"{rid}: pages={pages}, rows={rows}\")\n",
    "    except Exception as e:\n",
    "        stats.append((rid, None, None))\n",
    "        print(f\"FAILED {rid}: {e}\")\n",
    "\n",
    "final_df = reduce(lambda a, b: a.unionByName(b), dfs) if dfs else None\n",
    "final_df"
