    "def build_rename_map(old_fields: List[str], canonical_fields: List[str]) -> Dict[str, str]:\n",
    "    \"\"\"\n",
    "    - If counts match, use positional mapping.\n",
    "    - Overlay manual renames, but SKIP any rename where the target already exists in old_fields\n",
    "      (prevents duplicates like BNF_CHEMICAL_SUBSTANCE_CODE twice).\n",
    "    \"\"\"\n",
    "    mapping: Dict[str, str] = {}\n",
    "\n",
    "    # Positional mapping when same length\n",
    "    if len(old_fields) == len(canonical_fields):\n",
    "        mapping.update(dict(zip(old_fields, canonical_fields)))\n",
    "\n",
    "    # Guarded manual renames\n",
    "    def add(old_name: str, new_name: str):\n",
    "        if old_name in old_fields and new_name in canonical_fields:\n",
    "            # Critical guard: don't rename into an existing column name\n",
    "            if new_name in old_fields:\n",
    "                return\n",
    "            mapping[old_name] = new_name\n",
    "\n",
    "    add(\"BNF_CHEMICAL_SUBSTANCE\", \"BNF_CHEMICAL_SUBSTANCE_CODE\")\n",
    "    add(\"CHEMICAL_SUBSTANCE_BNF_DESCR\", \"BNF_CHEMICAL_SUBSTANCE\")\n",
    "\n",
    "    add(\"BNF_CODE\", \"BNF_PRESENTATION_CODE\")\n",
    "    add(\"BNF_DESCRIPTION\", \"BNF_PRESENTATION_NAME\")\n",
    "\n",
    "    add(\"STP_NAME\", \"ICB_NAME\")\n",
    "    add(\"STP_CODE\", \"ICB_CODE\")\n",
    "\n",
    "    return mapping\n",
    "\n",
    "print(\"Rename-map ready.\")"
   ]
  },
