   "outputs": [
    {
     "data": {
      "application/vnd.livy.statement-meta+json": {
       "execution_finish_time": "2025-12-21T23:10:36.1809566Z",
       "execution_start_time": "2025-12-21T23:10:35.867789Z",
       "livy_statement_state": "available",
       "normalized_state": "finished",
       "parent_msg_id": "6d053060-9d60-4f31-853a-0dd0df21a307",
       "queued_time": "2025-12-21T23:10:35.8664725Z",
       "session_id": "23ef4152-6901-45ad-bab4-46b7f1347ea9",
       "session_start_time": null,
       "spark_pool": null,
       "state": "finished",
       "statement_id": 16,
