         "2": "spu_PedigreeIndex_MixedHerds",
         "3": "-- COPY OF spu_PedigreeIndex_MixedHerds for Society = 9 Multiple Evaluations.    /*=====================================================================================================================*/  /* Stored Procedure: \tspu_PedigreeIndex_MixedHerds  \t\t\t\t\t\t\t\t\t\t\t\t           */  /* Author: \t\tBrian Phillips\t\t\t\t  \t\t\t\t\t\t\t\t                        */  /* Date: \t\t16/10/1\t\t\t\t\t\t\t\t\t\t\t\t\t           */  /* Description:\t\tCalculate Pedigree Index for an animal\t\t\t\t\t\t\t\t\t                        */  /*=====================================================================================================================*/    CREATE Procedure spu_PedigreeIndex_MixedHerds  \t\t\t@pintAnimalID  integer,   \t\t\t@Calf_EvalGroup tinyint,  \t\t\t@Sire_EvalGroup tinyint,  \t\t\t@Dam_EvalGroup\ttinyint,  \t\t\t@pintMilk integer output,  \t\t\t@psngBFatKg  decimal (10,1) output,   \t\t\t@psngProtKg decimal (10,1) output,  \t\t\t@psngBFatPc decimal (10,2) output,  \t\t\t@psngProtPc decimal (10,2) output,  \t\t\t@pintPin integer output,  \t\t\t@pintPLI integer output,  \t\t\t@pintTOP integer output,  \t\t\t@pintRlb integer output,  \t\t\t@pstrCalculatedFrom varchar(30) output,  \t\t\t@psngPTAT decimal (10,2) output,  \t\t\t@pstrCalculatedFromType varchar(30) output,  \t\t\t@pstrPTAUpdateMkr varchar(1) output,    /* Set to 'U'pdate, 'I'nsert or blank to do nothing at all */  \t\t\t@pstrTypeUpdateMkr varchar(1) output,  /* Set to 'U'pdate, 'I'nsert or blank to do nothing at all */  \t\t\t@ErrorText varchar(255) output,  \t\t\t@rc integer output   AS  \tdeclare @sngMilk decimal (10,5)  \tdeclare @sngPin decimal (10,5)  \tdeclare @sngPLI decimal (10,5)  \tdeclare @sngTOP decimal (10,5)  \tdeclare @sngRlb decimal (10,5)  \tdeclare @intMonth integer  \tdeclare @intYear integer  \tdeclare @intError  integer  \tdeclare @intRowcount integer  \tdeclare @PedigreeIndexMkr varchar(1)    \tdeclare @intSireID  integer  \tdeclare\t@sngMilkSire decimal (10,5)  \tdeclare\t@sngBFatKgSire  decimal (10,5)   \tdeclare\t@sngProtKgSire decimal (10,5)  \tdeclare\t@sngBFatPcSire decimal (10,5)  \tdeclare\t@sngProtPcSire decimal (10,5)  \tdeclare\t@sngPinSire decimal (10,5)  \tdeclare\t@sngPLISire decimal (10,5)  \tdeclare\t@sngTOPSire decimal (10,5)  \tdeclare\t@sngRlbSire decimal (10,5)  \tdeclare\t@strCalculatedFromSire varchar(30)   \tdeclare\t@sngPTATSire decimal (10,5)  \tdeclare\t@strCalculatedFromTypeSire varchar(30)     \tdeclare @intDamID  integer  \tdeclare\t@sngMilkDam decimal (10,5)  \tdeclare\t@sngBFatKgDam  decimal (10,5)   \tdeclare\t@sngProtKgDam decimal (10,5)  \tdeclare\t@sngBFatPcDam decimal (10,5)  \tdeclare\t@sngProtPcDam decimal (10,5)  \tdeclare\t@sngPinDam decimal (10,5)  \tdeclare\t@sngPLIDam decimal (10,5)  \tdeclare\t@sngTOPDam decimal (10,5)  \tdeclare\t@sngRlbDam decimal (10,5)  \tdeclare\t@strCalculatedFromDam varchar(30)   \tdeclare\t@sngPTATDam decimal (10,5)  \tdeclare\t@strCalculatedFromTypeDam varchar(30)     \tdeclare @sngPinPar1 decimal (10,5)  \tdeclare @sngPinPar2 decimal (10,5)  \tdeclare @sngPinPar3 decimal (10,5)    \t/* Set up default values */  \tselect @rc = 1  /* Error */  \tselect @ErrorText = ''  \tselect @pintMilk = null  \tselect @psngBFatKg = null  \tselect @psngProtKg = null  \tselect @psngBFatPc = null  \tselect @psngProtPc = null  \tselect @pintPin = null  \tselect @pintPLI = null  \tselect @pintTOP = null  \tselect @pintRlb = null  \tselect @pstrCalculatedFrom = ''  \tselect @psngPTAT = null  \tselect @pstrCalculatedFromType = ''  \tselect @PedigreeIndexMkr = ''  \tselect @pstrPTAUpdateMkr = ''  \tselect @pstrTypeUpdateMkr = ''    \tset nocount on    Process_PTA:  \t/* Establish whether the animal has a PTA. If so, don't bother with a Pedigree Index */  \tSELECT @PedigreeIndexMkr = PedigreeIndexMkr   \tFROM tblPTA  \tWHERE \tAnimal_ID = @pintAnimalID  \tAND\tintEvaluationGroup = @Calf_EvalGroup  \tAND \tstrPublishStatus = 'X'    \tselect @intError = @@Error, @intRowcount = @@Rowcount    \tif @intError <> 0    \tbegin  \t\tselect @ErrorText = 'spu_PedigreeIndex_MixedHerds: Unable to select from tblPTA'  \t\tgoto spu_PedigreeIndex_MixedHerds_Error  \tend  \t\t  \tif @intRowcount = 0  \tbegin   \t\tselect @pstrPTAUpdateMkr = 'I'  \tend  \telse  \tbegin   \t\tselect @pstrPTAUpdateMkr =  \t\t\tCASE @PedigreeIndexMkr  \t\t\t\tWHEN 'N'     THEN  ''\t/* No update or insert needed */  \t\t\t\tWHEN 'Y'     THEN  'U'   /* Update the existing pedigree index */  \t\t\t\tELSE  'I'\t\t/* Insert a new pedigree index */  \t\t\tEND  \tend    \tif @pstrPTAUpdateMkr  = ''  \tbegin  \t\t/* Animal already has a PTA. Just see if we can get a pedigree index for Type. */  \t\tselect @pstrTypeUpdateMkr = ''  \t\tgoto Process_Type\t\t  \tend    \t/* Get the animal's parents */  \tSELECT @intSireID = sire_id,   \t                @intDamID = dam_id  \t FROM tblAllAnimals   \t WHERE Animal_ID = @pintAnimalID    \tselect @intError = @@Error, @intRowcount = @@Rowcount    \tif @intError <> 0 or @intRowcount = 0    \tbegin  \t\tselect @ErrorText = 'spu_PedigreeIndex_MixedHerds: Unable to select from tblAllAnimals'  \t\tgoto spu_PedigreeIndex_MixedHerds_Error  \tend    \tif @intSireID is null  \tbegin  \t\tselect @pstrCalculatedFrom  = 'NO SIRE'  \t\tgoto Process_Type  \tend    \tif @intDamID is null  \tbegin  \t\tselect @pstrCalculatedFrom  = 'NO DAM'  \t\tgoto Process_Type  \tend    \t/* Get the sire's side */  \texec spu_PedigreeIndexProduction_Society9  \t\t\t\t'M',  \t\t\t\t@intSireID,   \t\t\t\t@Sire_EvalGroup,  \t\t\t\t@sngMilkSire output,  \t\t\t\t@sngBFatKgSire output,   \t\t\t\t@sngProtKgSire output,  \t\t\t\t@sngBFatPcSire output,  \t\t\t\t@sngProtPcSire output,  \t\t\t\t@sngPinSire output,  \t\t\t\t@sngPLISire output,  \t\t\t\t@sngTOPSire output,   \t\t\t\t@sngRlbSire output,  \t\t\t\t@strCalculatedFromSire output,  \t\t\t\t@ErrorText output,  \t\t\t\t@rc output    \tif @rc = 1   \tbegin  \t\tgoto spu_PedigreeIndex_MixedHerds_Error  \tend    \tif @rc = 0 and @sngRlbSire is null  \tbegin \t\t/* Calculated from message will be something like 'NO SIRE'S SIRE',  \t\t    so pass this back as the reason for non-calculation of the Pedigree Index */  \t\tselect @pstrCalculatedFrom = @strCalculatedFromSire  \t\tgoto Process_Type  \tend    \t/* Get the dam's side */  \texec spu_PedigreeIndexProduction_Society9  \t\t\t\t'F',  \t\t\t\t@intDamID,   \t\t\t\t@Dam_EvalGroup,  \t\t\t\t@sngMilkDam output,  \t\t\t\t@sngBFatKgDam output,   \t\t\t\t@sngProtKgDam output,  \t\t\t\t@sngBFatPcDam output,  \t\t\t\t@sngProtPcDam output,  \t\t\t\t@sngPinDam output,  \t\t\t\t@sngPLIDam output,  \t\t\t\t@sngTOPDam output,  \t\t\t\t@sngRlbDam output,  \t\t\t\t@strCalculatedFromDam output,  \t\t\t\t@ErrorText output,  \t\t\t\t@rc output     \tif @rc = 1   \tbegin  \t\tgoto spu_PedigreeIndex_MixedHerds_Error  \tend    \tif @rc = 0 and @sngRlbDam is null  \tbegin \t\t/* Calculated from message will be something like 'NO DAM'S SIRE',  \t\t    so pass this back as the reason for non-calculation of the Pedigree Index */  \t\tselect @pstrCalculatedFrom = @strCalculatedFromDam  \t\tgoto Process_Type  \tend    \t/* Produce the Pedigree Index */  \tselect @sngMilk = (@sngMilkSire + @sngMilkDam) / 2.0  \tselect @psngBFatKg = (@sngBFatKgSire + @sngBFatKgDam) / 2.0   \tselect @psngProtKg = (@sngProtKgSire + @sngProtKgDam) / 2.0  \tselect @psngBFatPc = (@sngBFatPcSire + @sngBFatPcDam) / 2.0  \tselect @psngProtPc = (@sngProtPcSire + @sngProtPcDam) / 2.0  /*\tselect @sngPin = (@sngPinSire + @sngPinDam) / 2.0 */  \tselect @sngPLI= (@sngPLISire + @sngPLIDam) / 2.0  \tselect @sngTOP= (@sngTOPSire + @sngTOPDam) / 2.0  \tselect @sngRlb = (@sngRlbSire + @sngRlbDam) / 4.0  \tselect @pstrCalculatedFrom = @strCalculatedFromSire + ', ' + @strCalculatedFromDam    \t/* Round the return values. Note that fat and protein kg and % are automatically   \t   rounded by being declared with the appropriate number of decimal places */  \tif @sngMilk > 0   \t\tselect @pintMilk = @sngMilk + 0.5  \telse  \t\tselect @pintMilk = @sngMilk - 0.5    /*\tif @sngPin > 0   \t\tselect @pintPin = @sngPin + 0.5  \telse  \t\tselect @pintPin = @sngPin - 0.5  */    \tif @sngPLI > 0   \t\tselect @pintPLI = @sngPLI + 0.5  \telse  \t\tselect @pintPLI = @sngPLI - 0.5    \tif @sngTOP > 0   \t\tselect @pintTOP = @sngTOP + 0.5  \telse  \t\tselect @pintTOP = @sngTOP - 0.5    \tselect @pintRlb = @sngRlb + 0.5    \t/* Calculate the PIN so that it will make sense if the farmer calculates it from the certificate.  \t    Note that we are using the rounded return values in the calculation. This replaces the   \t    Parent Average calculation coded above. */  \tSELECT @sngPinPar1 = sngPinPar1,   \t               @sngPinPar2 = sngPinPar2,  \t\t  @sngPinPar3 = sngPinPar3  \t FROM tlkpPinFormula     \tselect @intError = @@Error, @intRowcount = @@Rowcount    \tif @intError <> 0 or @intRowcount <> 1    \tbegin  \t\tselect @ErrorText = 'spu_PedigreeIndex_MixedHerds: Unable to select from tlkpPinFormula'  \t\tgoto spu_PedigreeIndex_MixedHerds_Error  \tend    \tselect @sngPin = (@pintMilk * @sngPinPar1) + (@psngBFatKg * @sngPinPar2) + (@psngProtKg * @sngPinPar3)\t    \tif @sngPin > 0   \t\tselect @pintPin = @sngPin + 0.5  \telse  \t\tselect @pintPin = @sngPin - 0.5    Process_TYPE:  \t/* Now get the Pedigree Index for type */    \t/* Establish whether the animal has a PTAT. If so, use this. */  \tSELECT @PedigreeIndexMkr = PedigreeIndexMkr  \tFROM tblType  \tWHERE Animal_ID = @pintAnimalID  \tAND strPublishStatusUK = 'X'    \tselect @intError = @@Error, @intRowcount = @@Rowcount    \tif @intError <> 0    \tbegin  \t\tselect @ErrorText = 'spu_PedigreeIndex_MixedHerds: Unable to select from tblPTAT'  \t\tgoto spu_PedigreeIndex_MixedHerds_Error  \tend  \t\t  \tif @intRowcount = 0  \tbegin   \t\tselect @pstrTypeUpdateMkr = 'I'  \tend  \telse  \tbegin  \t\tselect @pstrTypeUpdateMkr =  \t\t\tCASE @PedigreeIndexMkr  \t\t\t\tWHEN 'N'     THEN  ''\t/* No update or insert needed */  \t\t\t\tWHEN 'Y'     THEN  'U'   /* Update the existing pedigree index */  \t\t\t\tELSE  'I'\t\t/* Insert a new pedigree index */  \t\t\tEND  \tend    \tif @pstrTypeUpdateMkr  = ''  \tbegin  \t\t/* Animal already has a Type Proof.  */  \t\tgoto On_Success\t\t  \tend    /*\tif @@RowCount > 0  \tbegin  \t\t-- Animal has Type in its own right, so set up message as eg. 'PTAT (AUG2001)'   \t\tselect @pstrCalculatedFromType =  \t\t\t'PTAT (' +  \t\t\tCASE @intMonth    \t\t\t\tWHEN 1     THEN  'JAN'    \t\t\t\tWHEN 2     THEN  'FEB'    \t\t\t\tWHEN 3     THEN  'MAR'    \t\t\t\tWHEN 4     THEN  'APR'     \t\t\t\tWHEN 5     THEN  'MAY'    \t\t\t\tWHEN 6     THEN  'JUN'    \t\t\t\tWHEN 7     THEN  'JUL'    \t\t\t\tWHEN 8     THEN  'AUG'    \t\t\t\tWHEN 9     THEN  'SEP'    \t\t\t\tWHEN 10   THEN  'OCT'    \t\t\t\tWHEN 11   THEN  'NOV'    \t\t\t\tWHEN 12   THEN  'DEC'    \t\t\t\tELSE  ''        \t\t\tEND  \t\t\t+ rtrim(cast(@intYear as char)) + ')'  \t\t  \t\tselect @rc = 0  \t\tselect @ErrorText = 'Successfully calculated Pedigree Index'  \t\tgoto spu_PedigreeIndex_MixedHerds_Exit\t\t  \tend  */    \t/* Get the sire's side */  \texec spu_PedigreeIndexType  \t\t\t\t'M',  \t\t\t\t@intSireID,   \t\t\t\t@sngPTATSire output,   \t\t\t\t@strCalculatedFromTypeSire output,  \t\t\t\t@ErrorText output,  \t\t\t\t@rc output     \tif @rc = 1   \tbegin  \t\tgoto spu_PedigreeIndex_MixedHerds_Error  \tend    \tif @rc = 0 and @sngPTATSire is null  \tbegin \t\t/* Calculated from message will be something like 'NO SIRE'S SIRE',  \t\t    so pass this back as the reason for non-calculation of the Pedigree Index */  \t\tselect @pstrCalculatedFromType = @strCalculatedFromTypeSire  \t\tgoto On_Success  \tend    \t/* Get the dam's side */  \texec spu_PedigreeIndexType  \t\t\t\t'F',  \t\t\t\t@intDamID,   \t\t\t\t@sngPTATDam output,   \t\t\t\t@strCalculatedFromTypeDam output,  \t\t\t\t@ErrorText output,  \t\t\t\t@rc output     \tif @rc = 1   \tbegin  \t\tgoto spu_PedigreeIndex_MixedHerds_Error  \tend    \tif @rc = 0 and @sngPTATDam is null  \tbegin \t\t/* Calculated from message will be something like 'NO DAM'S SIRE',  \t\t    so pass this back as the reason for non-calculation of the Pedigree Index */  \t\tselect @pstrCalculatedFromType = @strCalculatedFromTypeDam  \t\tgoto On_Success  \tend    \t/* Produce the Pedigree Index for Type*/  \tselect @psngPTAT = (@sngPTATSire + @sngPTATDam) / 2.0  \tselect @pstrCalculatedFromType = @strCalculatedFromTypeSire + ', ' + @strCalculatedFromTypeDam    On_Success:  \t/* Set the return code to 0, indicating success */  \tselect @rc = 0  \tselect @ErrorText = 'Successfully calculated Pedigree Index'  \t  spu_PedigreeIndex_MixedHerds_Exit:  \tset nocount off  \treturn    spu_PedigreeIndex_MixedHerds_Error:  \t/* Set the return code to 1, indicating failure */  \tselect @rc = 1  \tprint 'An error has occurred in spu_PedigreeIndex_MixedHerds.'  \tprint @ErrorText  \tgoto spu_PedigreeIndex_MixedHerds_Exit",
         "4": "7940",
         "5": "503",
         "6": "1. Stored Procedure Name: spu_PedigreeIndex_MixedHerds\n2. Stored Procedure Complexity: Complex\n3. Logic can be replicated in Dataverse using Power Automate: Yes\n4. Purpose: Calculate Pedigree Index for an animal\n5. Summary of stored procedure:\n- It is a stored procedure named spu_PedigreeIndex_MixedHerds that calculates the Pedigree Index for an individual animal using mixed herd evaluation group data.\n- It declares and initialises a range of local variables to hold milking, composition, and Pedigree Index components, as well as update markers and error handling fields.\n- It first determines whether the animal has a PTA entry and sets PTA-related update markers accordingly, influencing whether the Pedigree Index should be updated or inserted.\n- If the PTA path is not blank, it retrieves the sire and dam IDs from tblAllAnimals and handles cases where a parent is missing by setting the CalculatedFrom indicator.\n- It calls spu_PedigreeIndexProduction_Society9 for the sire side to obtain milk, BFatKg, ProtKg, BFatPc, ProtPc, Pin, PLI, TOP, Rlb and related calculated-from messages, with error handling on return.\n- It performs a similar call for the dam side to obtain the corresponding metrics and messages, again with error checking.\n- It computes the Pedigree Index components by averaging the sire and dam values (milk, fat and protein measures, PLI, TOP, Rlb) and concatenates the CalculatedFrom strings from both parents.\n- It uses tlkpPinFormula to fetch parameters and calculates Pin from milk and composition, applying rounding to the final Pin value.\n- It determines the Type Pedigree Index by querying tblType and invoking spu_PedigreeIndexType for both sire and dam, averaging PTAT values to produce psngPTAT and building CalculatedFromType messages.\n- It sets the return code to 0 and marks the operation as successfully calculated, returning the computed Pedigree Index values and messages.\n- In the event of errors at any step, it sets rc to 1, populates ErrorText, and exits with an error notice."
        },
        {
         "0": "TCS",
         "1": "dbo",
         "2": "usp_MobileTCS_ImportIslandData",
         "3": "            --**************************************************************************************************  --*        usp_MobileTCS_ImportFemaleMember...Developed by Franz Ayestaran Revised 06/01/09        *  --* Import Jersey and guernsey File into tempoary tables, process and insert into tblFemale/Member *  --**************************************************************************************************    --12\tJERSEY ISLAND\tJersey Island\tR  --13\tGUERNSEY ISLAND\tGuernsey Island\tU    -- MainHerdPrefix = HerdPrefix √  -- Prefix = HerdPrefix √  -- MainCustomerNo = CustomerNo √  -- Ins_type = insp_type √  -- hbn_flag = H √  -- prev_class √  -- Null = Blank    --Visit_ID = 0  --Visit_No = 1  --Program = A  --n = pedigree animal  --f = foundation animal    CREATE PROCEDURE [dbo].[usp_MobileTCS_ImportIslandData]  @intSocietyId int,  @FieldOfficer int,  @strErrorText VARCHAR(255) OUTPUT  AS  \tSET LOCK_TIMEOUT 2000    \tDECLARE @FemaleRows INT  \tDECLARE @MemberRows INT      DECLARE @intRC SMALLINT     \tDECLARE @strRootDir VARCHAR(50)  \tDECLARE @strImportDir VARCHAR(50)  \tDECLARE @strLogDir VARCHAR(50)  \tDECLARE @strErrorDir VARCHAR(50)  \tDECLARE @strFormatDir VARCHAR(50)  \tDECLARE @strFileName VARCHAR(100)  \tDECLARE @strLogFile VARCHAR(100)  \tDECLARE @strErrorFile VARCHAR(100)  \tDECLARE @strFormatFile VARCHAR(100)  \tDECLARE @xmdstr VARCHAR(255)  \tDECLARE @strNewFileName VARCHAR(100)  \tDECLARE @strImportArchive VARCHAR(100)  \tDECLARE @SeqNo SMALLINT  \tDECLARE @Animal_ID INT  \tDECLARE @CustomerNo INT  \tDECLARE @LastCustomerNo INT  \tDECLARE @DateTime VARCHAR(25)  \tSET @strErrorText = ''    \tSET @DateTime = CONVERT(VARCHAR(8),GETDATE(),112) + LEFT(CONVERT(VARCHAR(8),GETDATE(),108),2) + SUBSTRING(CONVERT(VARCHAR(8),GETDATE(),108),4,2)    \tSELECT @intRC = 1    \t-- Setup Environmental Variables  \tSELECT @strRootDir = strRootDir,   \t\t@strImportDir = strRootDir + strImportDir,  \t\t@strLogDir = strRootDir + strLogDir,   \t\t@strErrorDir = strRootDir + strErrorDir,  \t\t@strFormatDir = strRootDir + strFormatDir   \tFROM zstblTCSSystem  \tWHERE intSocietyID = @intSocietyId    \t-- Import '\\\\Linmack\\Tcs\\Import\\Female.txt'  \tSELECT @strFileName = @strImportDir + 'Female.txt'  \tSELECT @strLogFile = @strLogDir + 'Female.log'   \tSELECT @strErrorFile = @strErrorDir + 'Female.err'  \tSELECT @strFormatFile = @strFormatDir + 'Female.fmt'    \t/* Check if file exists */  \tSELECT @xmdstr = 'Dir ' + @strFilename  \tEXECUTE @intRC=master.dbo.xp_cmdshell  @xmdstr, no_output  \tIF @intRC<>0   \tBEGIN  \t\t/* Unable to find file */  \t\tSELECT @strErrorText = 'usp_MobileTCS_ImportIslandData: Unable to find file ' + @strFilename  \t\tGOTO usp_MobileTCS_ImportIslandData_Error  \tEND    \tIF @intRC=0   \tBEGIN          --Retrieve Next Animal ID  \t\tDECLARE @MobileNextAnimalId AS INT  \t\tSELECT @MobileNextAnimalId = Value FROM zstblTCSSystemValues  \t\tWHERE Identifier = 'MobileNextAnimalId'  \t\t--Clear and Reseed Table  \t\tTRUNCATE TABLE tmpMobileFemale  \t\t--Reseed Table     <Table Name>    <Cmd>         <Start>  \t\tDBCC CHECKIDENT (tmpMobileFemale , reseed, @MobileNextAnimalId)  \tEND  \t  \t/* Load the data from the file into table */  \tSELECT @xmdstr = 'cmd.exe /c ' + '\"' +   \t\t\t 'bcp ' + rtrim(db_name()) + '.dbo.tmpMobileFemale ' +  \t\t\t 'in ' + @strFilename  + ' ' +  \t\t\t'-S' + @@SERVERNAME + ' ' +   \t\t\t --'-Uprogramming -Ppassword ' +  \t\t\t'-T ' + --Trusted Connection  \t\t\t '-m0 ' +  \t\t\t '-f'+ @strFormatFile + ' ' +  \t\t\t '-e'+ @strErrorFile + ' ' +  \t\t\t '-o'+ @strLogFile + '\"'    \t--PRINT @xmdstr  \tEXECUTE @intrc=master.dbo.xp_cmdshell  @xmdstr , no_output  \tSET @FemaleRows = (SELECT COUNT (*) FROM tmpMobileFemale)    \tIF @intRC>0 \t  \tBEGIN  \t\tSELECT @strErrorText = 'usp_MobileTCS_ImportIslandData: Unable to load file ' + @strFilename  \t\tGOTO usp_MobileTCS_ImportIslandData_Error  \tEND    \t-- Import '\\\\Linmack\\Tcs\\Import\\member.txt'  \tSELECT @strFileName = @strImportDir + 'Member.txt'  \tSELECT @strLogFile = @strLogDir + 'Member.log'   \tSELECT @strErrorFile = @strErrorDir + 'Member.err'  \tSELECT @strFormatFile = @strFormatDir + 'Member.fmt'    \t/* Check if file exists */  \tSELECT @xmdstr = 'Dir ' + @strFilename  \tEXECUTE @intRC=master.dbo.xp_cmdshell  @xmdstr, no_output  \tIF @intRC<>0   \tBEGIN  \t\t/* Unable to find file */  \t\tSELECT @strErrorText = 'usp_MobileTCS_ImportIslandData: Unable to find file ' + @strFilename  \t\tGOTO usp_MobileTCS_ImportIslandData_Error  \tEND    \tIF @intRC=0   \tBEGIN          --Retrieve Next Customer Number  \t\tDECLARE @MobileNextCustomerNo as INT  \t\tSELECT @MobileNextCustomerNo = Value FROM zstblTCSSystemValues  \t\tWHERE Identifier = 'MobileNextCustomerNo'  \t\tTRUNCATE TABLE tmpMobileMember  \t\t--Reseed Table     <Table Name>    <Cmd>         <Start>  \t\tDBCC CHECKIDENT (tmpMobileMember, reseed, @MobileNextCustomerNo)  \tEND  \t  \t/* Load the data from the file into table */  \tSELECT @xmdstr = 'cmd.exe /c ' + '\"' +   \t\t\t 'bcp ' + rtrim(db_name()) + '.dbo.tmpMobileMember ' +  \t\t\t 'in ' + @strFilename  + ' ' +  \t\t\t'-S' + @@SERVERNAME + ' ' +   \t\t\t --'-Uprogramming -Ppassword ' +  \t\t\t'-T ' + --Trusted Connection  \t\t\t '-m0 ' +  \t\t\t '-f'+ @strFormatFile + ' ' +  \t\t\t '-e'+ @strErrorFile + ' ' +  \t\t\t '-o'+ @strLogFile + '\"'    \tPRINT @xmdstr  \tEXECUTE @intrc=master.dbo.xp_cmdshell  @xmdstr , no_output  \tSET @MemberRows = (SELECT COUNT (*) FROM tmpMobileMember)    \tIF @intRC>0 \t  \tBEGIN  \t\tSELECT @strErrorText = 'usp_MobileTCS_ImportIslandData: Unable to load file ' + @strFilename  \t\tGOTO usp_MobileTCS_ImportIslandData_Error  \tEND    \t-- Insert SocietyID, CustomerNo and Breed\t  \tIF @intSocietyId = 12   \tBEGIN  \t\t--UPDATE tmpMobileFemale SET SocietyID = '12', Breed = '74', sire_breed = '74', FieldOfficer = @FieldOfficer  \t\tUPDATE tmpMobileFemale SET SocietyID = '12', FieldOfficer = @FieldOfficer  \t\tUPDATE tmpMobileMember SET SocietyID = '12', FieldOfficer = @FieldOfficer, insp_type = 'R'  \tEND    \tIF @intSocietyId = 13   \tBEGIN  \t\t--UPDATE tmpMobileFemale SET SocietyID = '13', Breed = '75', sire_breed = '75', FieldOfficer = @FieldOfficer  \t\tUPDATE tmpMobileFemale SET SocietyID = '13', FieldOfficer = @FieldOfficer  \t\tUPDATE tmpMobileMember SET SocietyID = '13', FieldOfficer = @FieldOfficer, insp_type = 'U'  \tEND    \t--DECLARE @customerNo INT  \tDECLARE @Class VARCHAR(2)    \t--Added 18/06/2010  \t--Change Age to be YYMM. It is imported as MMYY  \tUPDATE tmpMobileFemale  \tSET age = RIGHT(age,2) + LEFT(age,2)  \t--End added 18/06/2010    \t--Synchronise customerno between both tables  \tUPDATE T1   \tSET CustomerNo = T2.CustomerNo   \tFROM tmpMobileFemale T1  \tJOIN tmpMobileMember T2      ON T1.Herd_Prefix = T2.Herd_Prefix    \t--Convert prev_class from numeric to aplha code  \t  \tUPDATE tmpMobileFemale SET prev_class =      CASE  \t   WHEN prev_class = '1' THEN 'P'  \t   WHEN prev_class = '2' THEN 'F'  \t   WHEN prev_class = '3' THEN 'G'  \t   WHEN prev_class = '4' THEN 'GP'  \t   WHEN prev_class = '5' THEN 'VG'  \t   WHEN prev_class = '6' THEN 'EX'      ELSE ''      END    \tSELECT @SeqNo = 1  \tSET @LastCustomerNo = 0  \tDECLARE tmpMobileFemale_cursor SCROLL CURSOR FOR SELECT animal_id, CustomerNo FROM tmpMobileFemale ORDER BY customerNo OPEN tmpMobileFemale_cursor      FETCH FIRST FROM tmpMobileFemale_cursor INTO @Animal_ID, @CustomerNo      WHILE @@Fetch_Status = 0         BEGIN  \t\tIF @CustomerNo <> @LastCustomerNo   \t\t\tBEGIN  \t\t\t\tSELECT @SeqNo = 1  \t\t\t\tSET @LastCustomerNo = @CustomerNo  \t\t\tEND  \t\tUPDATE tmpMobileFemale SET SeqNo = @SeqNo WHERE animal_id = @Animal_ID  \t\tFETCH NEXT FROM tmpMobileFemale_cursor INTO @Animal_ID, @CustomerNo  \t\tSET @SeqNo = @SeqNo + 1  \t  END    \tCLOSE tmpMobileFemale_cursor      DEALLOCATE tmpMobileFemale_cursor      \t--Set Next Animal ID In Table  \tUPDATE zstblTCSSystemValues SET Value = @FemaleRows + @MobileNextAnimalId  \tWHERE Identifier = 'MobileNextAnimalId'     \t--Set Next Customer Number In Table  \tUPDATE zstblTCSSystemValues SET Value = @MemberRows + @MobileNextCustomerNo  \tWHERE Identifier = 'MobileNextCustomerNo'     \t-- Copy data to tblMobileFemale  \tINSERT INTO tblMobileFemale (HerdPrefix, animalname, breed, hbn, hbn_flag, sr_code, eartag1, eartag2, prev_class, prev_score, times_ex, sire_breed, sire_hbn, age, line_no, insp_type, animal_id, customerno, societyid, fieldofficer, mainherdprefix, maincustomerno, prefix, sire_prefix, sire_name, lift_prog_test, award_lit, DateLastCalved, MRO_Prefix, intNoOfCalves, ysnProvisional, DownloadDate, SeqNo)  \t--//XI0: Remove XI from eartag1  \tSELECT Herd_Prefix, [name], breed, RIGHT('000000000000' + RTRIM(hbn), 12), 'H', sr_code, REPLACE(REPLACE(eartag1,'UK',''), 'XI', ''), eartag2, prev_class, prev_score, times_ex, sire_breed, sire_hbn, age, RIGHT('0000' + rtrim(line_no),4),   \tCASE  \t   WHEN societyid = '12' THEN 'R'  \t   WHEN societyid = '13' THEN 'U'      ELSE ''  \tEND, animal_id, customerno, societyid, fieldofficer, Herd_Prefix, customerno, Calf_Prefix, '', '', '0', '', RIGHT('0000' + rtrim(Date_Calved),4), '', '', '', NULL, SeqNo  \tFROM tmpMobileFemale  \t-- Copy data to tblMobileMember  \tINSERT INTO tblMobileMember (HerdPrefix, mem_name, addr1, addr2, addr3, insp_type, customerno, societyid, fieldofficer, MainHerdPrefix, MainCustomerNo, MainSocietyId, addr4, County, PostCode, dd_mca_ind, MinistryNo, MRO, visit_id, visit_no, program, DownloadDate, RunDate, CompleteHerd, ResearchHerd, CoordinatesReqd)  \tSELECT Herd_Prefix, UPPER(breeder_name), UPPER(addr1), UPPER(addr2), UPPER(addr3), insp_type, customerno, societyid, fieldofficer, Herd_Prefix, CustomerNo, societyid, '', '', '', '', '', 'N', '0', '1', 'A', NULL, GETDATE(), 'N', 'N', 'Y'  \tFROM tmpMobileMember    \t--Rename the Female file & move it to the Archive folder  \tSELECT @strFileName = @strImportDir + 'Female'  \tSELECT @strNewFilename = 'Female_' + @DateTime + '.txt'   \tSELECT @xmdstr = 'Rename ' + @strFilename + '.txt ' + @strNewFileName    \t--PRINT @xmdstr    \tEXECUTE @intRC=master.dbo.xp_cmdshell  @xmdstr, no_output  \tIF @intRC<>0   \tBEGIN  \t\t/* Unable to find file */  \t\tSELECT @strErrorText = 'usp_MobileTCS_ImportIslandData: Unable to rename file ' + @strFilename  \t\tGOTO usp_MobileTCS_ImportIslandData_Error  \tEND    \tSELECT @strImportArchive = 'Archive'  \tSELECT @xmdstr = 'Move ' + @strImportDir + @strNewFileName + ' ' + @strImportDir + @strImportArchive    \t--PRINT @xmdstr    \tEXECUTE @intRC=master.dbo.xp_cmdshell  @xmdstr, no_output  \tIF @intRC<>0   \tBEGIN  \t\t/* Unable to find file */  \t\tSELECT @strErrorText = 'usp_MobileTCS_ImportIslandData: Unable to move file ' + @strNewFilename + ' to ' + @strImportArchive   \t\tGOTO usp_MobileTCS_ImportIslandData_Error  \tEND        --Rename the Member file & move it to the Archive folder  \tSELECT @strFileName = @strImportDir + 'Member'  \tSELECT @strNewFilename = 'Member_' + @DateTime + '.txt'   \tSELECT @xmdstr = 'Rename ' + @strFilename + '.txt ' + @strNewFileName    \t--PRINT @xmdstr    \tEXECUTE @intRC=master.dbo.xp_cmdshell  @xmdstr, no_output  \tIF @intRC<>0   \tBEGIN  \t\t/* Unable to find file */  \t\tSELECT @strErrorText = 'usp_MobileTCS_ImportIslandData: Unable to rename file ' + @strFilename  \t\tGOTO usp_MobileTCS_ImportIslandData_Error  \tEND    \tSELECT @strImportArchive = 'Archive'  \tSELECT @xmdstr = 'Move ' + @strImportDir + @strNewFileName + ' ' + @strImportDir + @strImportArchive    \t--PRINT @xmdstr    \tEXECUTE @intRC=master.dbo.xp_cmdshell  @xmdstr, no_output  \tIF @intRC<>0   \tBEGIN  \t\t/* Unable to find file */  \t\tSELECT @strErrorText = 'usp_MobileTCS_ImportIslandData: Unable to move file ' + @strNewFilename + ' to ' + @strImportArchive   \t\tGOTO usp_MobileTCS_ImportIslandData_Error  \tEND    \tSELECT @intRC = 0    usp_MobileTCS_ImportIslandData_Exit:  \tRETURN    usp_MobileTCS_ImportIslandData_Error:  \tSELECT @intRC = 1  \t--PRINT @strErrorText  \t--ROLLBACK TRANSACTION  \tGOTO usp_MobileTCS_ImportIslandData_Exit    RETURN",
         "4": "7932",
