         "0": "MilkRecording",
         "1": "dbo",
         "2": "uspLiveUpdateCalvesDamDetails",
         "3": "CREATE PROCEDURE dbo.uspLiveUpdateCalvesDamDetails  \t\t@DamMrAnimalId int  \t-- 23/01/2009 J Wall, Keep Archive Tables in step with live tables  -- 16/09/2003 J Wall update the dam details for all animals marked as calves of the animal  --      (Called by uspLiveUpdatePedigreeIdsForAnimal)  AS  -- Search an aimals lactations to find it's calves  UPDATE CALF SET   \tcalf.DamEarTag = dam.Eartag,   \tcalf.DamBreed = dam.Breed,   \tcalf.DamHbn = dam.Hbn,   \tcalf.DamSrCode = dam.SrCode,   \tcalf.DamName = RTRIM(LTRIM(RTRIM(dam.Prefix) + ' ' + LTRIM(dam.AnimalName))),   \tcalf.CisDamCowNo = dam.CisCowNo,   \tcalf.CisDamEarTagPrefix = dam.CisEarTagPrefix  FROM tblLactations l   INNER JOIN tblAnimals dam   \tON l.MrAnimalId = dam.MrAnimalId   INNER JOIN tblAnimals calf   \tON l.CalfMrAnimalId = calf.MrAnimalId  WHERE (l.MrAnimalId = @DamMrAnimalId)\t  UPDATE CALF SET   \tcalf.DamEarTag = dam.Eartag,   \tcalf.DamBreed = dam.Breed,   \tcalf.DamHbn = dam.Hbn,   \tcalf.DamSrCode = dam.SrCode,   \tcalf.DamName = RTRIM(LTRIM(RTRIM(dam.Prefix) + ' ' + LTRIM(dam.AnimalName))),   \tcalf.CisDamCowNo = dam.CisCowNo,   \tcalf.CisDamEarTagPrefix = dam.CisEarTagPrefix  FROM tblLactations l   INNER JOIN tblAnimals dam   \tON l.MrAnimalId = dam.MrAnimalId   INNER JOIN ArchiveAnimals calf   \tON l.CalfMrAnimalId = calf.MrAnimalId  WHERE (l.MrAnimalId = @DamMrAnimalId)\t    RETURN",
         "4": "997"
        },
