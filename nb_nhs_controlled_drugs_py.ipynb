         "1": "dbo",
         "2": "uspCDIAnimalDetailsForMovement",
         "3": "      CREATE PROCEDURE [dbo].[uspCDIAnimalDetailsForMovement]  \t@PedigreeAnimalId AS INTEGER,  \t@intCustomerNo  AS integer  \t--04/05/2011 J Wall - called from HukLibrary.PedigreeMovement  AS  DECLARE @AnimalDesc varchar(255)  DECLARE @Eartag varchar(50)  DECLARE @HerdPrefix varchar(30)  DECLARE @InHerd CHAR(1)  DECLARE @MrAnimalId int  DECLARE @MrHerdId int    -- get the Eartag  SELECT   \t@Eartag =  LTRIM(RTRIM(ISNULL(Ear_Tag,''))),  \t@AnimalDesc =  CASE  \t\t\t\tWHEN  master.dbo.FormattedName(Prefix, Animal_Name,Serial_No,Twin_Code,70)<>''   \t\t\t\t\t\tTHEN master.dbo.FormattedName(Prefix, Animal_Name,Serial_No,Twin_Code,70)  \t\t\t\tELSE Ear_Tag  \t\t\t\tEND,  \t--@AnimalDesc =   Ear_Tag  \t--\t\t+ ' ' + master.dbo.FormattedBreedHbn(Breed, HBN)  \t--\t\t+ ' ' + master.dbo.FormattedName(Prefix, Animal_Name,Serial_No,Twin_Code,70),  \t@HerdPrefix=Herd_Prefix,  \t@InHerd = CASE  \t\tWHEN  intOwnerCustomerNo=@intCustomerNo THEN 'Y'  \t\tELSE 'N'  \t\tEnd  FROM  animal.dbo.tblAllAnimals  WHERE Animal_ID = @PedigreeAnimalId    -- get the Milk recording Herd Animal Id (if it exists)  SELECT   \t@MrAnimalId= a.MrAnimalId,  \t@MrHerdId = a.HerdId  FROM  accounts.dbo.tblCustomerPrefixes AS cp   INNER JOIN tblHerds AS h   \tON cp.intCustomerNo2 = h.intCustomerNo   INNER JOIN tblAnimals AS a  \tON h.HerdId = a.HerdId  WHERE cp.intCustomerNo1 = @intCustomerNo   AND a.PtaAnimalId = @PedigreeAnimalId   AND a.Status = 'A'  -- If not found check if is marked as sold (has to be done in 2 steps as farmer may have multiple CIS herds  -- and transfer ani9mals between them if which case we want to make sure we get the alive animal)  IF @MrAnimalId IS null  \tSELECT   \t\t@MrAnimalId= a.MrAnimalId,  \t\t@MrHerdId = a.HerdId  \tFROM  accounts.dbo.tblCustomerPrefixes AS cp   \tINNER JOIN tblHerds AS h   \t\tON cp.intCustomerNo2 = h.intCustomerNo   \tINNER JOIN tblAnimals AS a  \t\tON h.HerdId = a.HerdId  \tWHERE cp.intCustomerNo1 = @intCustomerNo   \tAND a.PtaAnimalId = @PedigreeAnimalId   \tAND a.Status = 'S'    SELECT  \tAnimalDesc=isnull(@AnimalDesc,''),  \tEartag=isnull(@Eartag,''),  \tMrAnimalId=isnull(@MrAnimalId,0),  \tMrHerdId=isnull(@MrHerdId,0),  \tInHerd=isnull(@InHerd,'Y'),  \tHerdPrefix=@HerdPrefix",
         "4": "1556",
         "5": "2000",
         "6": "1. Stored Procedure Name: uspCDIAnimalDetailsForMovement\n2. Stored Procedure Complexity: Medium\n3. Logic can be replicated in Dataverse using Power Automate: Yes\n4. Purpose: To retrieve animal details required for movement processing by resolving the current ear tag, descriptive name, herd prefix, ownership status, and reference identifiers (MrAnimalId and MrHerdId) from related tables, using active records and a fallback for sold status.\n5. Summary of stored procedure:\n- Declares local variables for AnimalDesc, Eartag, HerdPrefix, InHerd, MrAnimalId and MrHerdId to hold computed values.\n- Retrieves the eartag and a display description for the animal from animal.dbo.tblAllAnimals, using a formatted name when available, otherwise falling back to the ear tag.\n- Computes InHerd as 'Y' when the owner customer number matches the provided customer number, otherwise 'N', and captures the HerdPrefix from Herd_Prefix.\n- Attempts to locate MrAnimalId and MrHerdId by joining customer prefixes, herds and animals where the customer number matches and the PtaAnimalId equals the pedigree animal, considering only active animals (Status = 'A').\n- If no active match is found, re-fetches MrAnimalId and MrHerdId using the same joins but with Status = 'S' to cover animals sold or moved to another CIS herd.\n- Returns the computed AnimalDesc, Eartag, MrAnimalId, MrHerdId, InHerd and HerdPrefix, using defaults if any value is NULL."
        },
        {
         "0": "MilkRecording",
         "1": "dbo",
         "2": "uspstageListRecorderUploadErrorsForMRO",
         "3": "CREATE PROCEDURE [dbo].[uspstageListRecorderUploadErrorsForMRO]  \t\t@MroIds int  -- 06/02/2007 J Wall Show all errors possible  -- 16/12/2005 J Wall Fix Recorder bug  -- 12/12/2005 J Wall Ignore informational messages ('HerdNo = *%')  -- 27/06/2005 J Wall added MRO Filter  -- 26/04/2005 J Wall Ignore Flag  -- 04/04/2005 J Wall List recorder Upload errors (used by StormAdmin/Listdeiscrepancies.aspx)  AS    --List the latests (for herd) recorder error where recording is not yet live  SELECT       \tMAX(r.DateUploaded) AS DateUploaded,   \tr.RecorderId,   \tr.Herdid  INTO #tmp1  FROM  vietblHerds h   INNER JOIN  tblSysRecordersUpLoadLog r WITH (NOLOCK)  \tON h.HerdId = r.Herdid   \tAND ISNULL(h.DatePutLive, DATEADD(year, - 1, GETDATE())) < r.DateUploaded  WHERE (r.Errormessage <> '')   and isnull(IgnoreErrors,'N')='N'  AND (NOT (r.Errormessage LIKE 'HerdNo = *%'))  and  h.MroId & @MroIds = h.MroId  GROUP BY r.RecorderId, r.Herdid    SELECT       \tt.Herdid,   \th.CisHerdNo,   \tt.DateUploaded,   \tErrormessage =  case  \t\twhen charindex(' System - ',l.Errormessage)>0 then  \t\t\tsubstring(l.Errormessage,  \t\t\tcharindex(' System - ',l.Errormessage) + 10,  \t\t\tLen(l.Errormessage)-(charindex(' System - ',l.Errormessage)) + 10)  \t\telse l.Errormessage  \t\tend,   \tRecorder = ISNULL(CAST(t.RecorderId AS varchar(255)), '') + ' - ' + ISNULL(LTRIM(r.strName), ''),  \tIdentifier=Case when rtrim(isnull(h.HerdPrefix1,''))='' then '(' + lower(a.strAddress1) + ')'  \t\telse h.HerdPrefix1  \t\tend,  \tUrlString = '<a href=ListDiscrepancies.aspx?ResetRecUploadId=' +   \t\tcast(l.UniqueRecId as varchar(12)) +'>Ignore</a>'  FROM  #tmp1 t   INNER JOIN vietblHerds h   \tON t.Herdid = h.HerdId   INNER JOIN tblSysRecordersUpLoadLog l WITH (NOLOCK)  \tON t.DateUploaded = l.DateUploaded   \tAND t.RecorderId = l.RecorderId   \tAND t.Herdid = l.Herdid   Left Outer Join tlkpMRO mro WITH (NOLOCK)  \t\ton h.MroId = mro.MroId  LEFT OUTER JOIN Accounts.dbo.tblRecorders r WITH (NOLOCK)  \tON t.RecorderId = r.intReference   \tAND r.intSocietyID = mro.Society  LEFT OUTER JOIN  Accounts.dbo.tblAddress a WITH (NOLOCK)  \t\tON h.intCustomerNo = a.intCustomerNo   \t\tAND a.intAddInd = 1  where t.DateUploaded> dateadd(day, -7, getdate())  Order By h.CisHerdNo  RETURN",
         "4": "1555",
         "5": "2001",
         "6": "1. Stored Procedure Name: uspstageListRecorderUploadErrorsForMRO\n2. Stored Procedure Complexity: Medium\n3. Logic can be replicated in Dataverse using Power Automate: Yes\n4. Purpose: To list the latest recorder upload errors for herds associated with a given MRO, to support StormAdmin display and allow ignoring specific errors.\n5. Summary of stored procedure:\n- The procedure accepts a single integer parameter @MroIds to filter the MROs.\n- It creates a temporary table #tmp1 containing the latest DateUploaded per RecorderId and Herdid where the upload occurred after the herd’s live date (or one year back if not live).\n- It filters results to include only non-empty error messages, and where IgnoreErrors is not marked as 'N', while excluding messages that match the pattern 'HerdNo = *%'.\n- It applies a bitwise filter using h.MroId & @MroIds = h.MroId to restrict results to the specified MROs.\n- It joins the temporary results with the VietblHerds and tblSysRecordersUpLoadLog data to assemble the final dataset.\n- It computes the Errormessage, extracting the portion after \"System - \" when present, otherwise using the original message.\n- It builds a Recorder field by combining the RecorderId with the corresponding recorder name, and constructs an Identifier from the herd prefix or address information.\n- It creates UrlString containing an Ignore link that references ResetRecUploadId for the corresponding entry.\n- Only records with DateUploaded within the last seven days are returned, and the results are ordered by CisHerdNo."
        },
        {
         "0": "MilkRecording",
         "1": "dbo",
         "2": "uspRecorderChangePassword",
         "3": "CREATE PROCEDURE [dbo].[uspRecorderChangePassword]  \t@OldPassword VARCHAR(30)  \t,@NewPassword VARCHAR(30)  \t,@NewPassword2 VARCHAR(30)  \t,@RecorderID INTEGER  AS  \tIF NOT EXISTS  \t\t(SELECT  \t\t\t*  \t\t FROM  \t\t\tAccounts.dbo.tblRecorders  \t\t WHERE  \t\t\tintReference = @RecorderID  \t\t\tAND intSocietyID = 10)  \tBEGIN  \t\tRAISERROR  \t\t\t\t('Recorder ID is not recognised',16,1)  \t\tRETURN  \tEND    \tIF NOT EXISTS  \t\t(SELECT  \t\t\t*  \t\t FROM  \t\t\tAccounts.dbo.tblRecorders  \t\t WHERE  \t\t\tintReference = @RecorderID  \t\t\tAND strWebPassword = @OldPassword  \t\t\tAND intSocietyID = 10)  \tBEGIN  \t\tRAISERROR  \t\t\t\t('Your current password is not correct',16,1)  \t\tRETURN  \tEND  \t  \tIF @NewPassword <> @NewPassword2  \tBEGIN  \t\tRAISERROR  \t\t\t\t('New passwords do not match',16,1)  \t\tRETURN  \tEND    \tIF EXISTS  \t\t(SELECT  \t\t\t*  \t\t FROM  \t\t\tAccounts.dbo.tblRecorders  \t\t WHERE  \t\t\tintReference = @RecorderID  \t\t\tAND strWebPassword = @NewPassword  \t\t\tAND intSocietyID = 10)  \tBEGIN  \t\tRAISERROR  \t\t\t\t('You can not use your current password as a new password',16,1)  \t\tRETURN  \tEND    \tIF LEN(@NewPassword) < 5 OR LEN(@NewPassword) > 15  \tBEGIN  \t\tRAISERROR  \t\t\t\t('New password must be between 5 and 15 characters in length',16,1)  \t\tRETURN  \tEND    \tIF ISNUMERIC(@NewPassword) = 1  \tBEGIN  \t\tRAISERROR  \t\t\t\t('New password must contain some alpha characters',16,1)  \t\tRETURN  \tEND    \tIF LEN(LEFT(SUBSTRING(@NewPassword, PATINDEX('%[0-9.-]%', @NewPassword), 8000),  \t\t\t   PATINDEX('%[^0-9.-]%', SUBSTRING(@NewPassword, PATINDEX('%[0-9.-]%', @NewPassword), 8000) + 'X') -1)) = 0  \tBEGIN  \t\tRAISERROR  \t\t\t\t('New password must contain some numeric characters',16,1)  \t\tRETURN  \tEND    \tIF PATINDEX('%[^a-zA-Z0-9]%', @NewPassword) > 0  \tBEGIN  \t\tRAISERROR  \t\t\t\t('Only alpha and numeric characters can be used for a new password',16,1)  \t\tRETURN  \tEND    \tINSERT INTO  \t\tAccounts.dbo.audittblRecorders  \tSELECT  \t\t*  \tFROM  \t\tAccounts.dbo.tblRecorders  \tWHERE  \t\tintReference = @RecorderID  \t\tAND intSocietyID = 10    \tUPDATE  \t\tAccounts.dbo.tblRecorders  \tSET  \t\tstrWebPassword = @NewPassword  \t\t,dtmLastAmendment = GETDATE()  \t\t,strLastAmendmentBy = 'uspRecorderChangePassword'  \t\t,DatePasswordChanged = GETDATE()  \tWHERE  \t\tintReference = @RecorderID  \t\tAND intSocietyID = 10    RETURN    GRANT EXECUTE ON [dbo].[uspRecorderChangePassword] TO MilkRecordingRole",
         "4": "1554",
         "5": "2002",
         "6": "1. Stored Procedure Name: uspRecorderChangePassword\n2. Stored Procedure Complexity: Complex\n3. Logic can be replicated in Dataverse using Power Automate: Yes\n4. Purpose: To change a recorder's web password for a given recorder ID after validating the old password, ensuring the new password meets policy constraints, auditing the change, updating the password and related metadata, and granting permission for execution.\n5. Summary of stored procedure:\n- It first verifies that the provided recorder identifier exists for society 10; otherwise it raises an error.\n- It then verifies that the provided old password matches the current web password for that recorder; otherwise it raises an error.\n- It checks that the new password and its confirmation match; otherwise it raises an error.\n- It ensures the new password is not the same as the current password; otherwise it raises an error.\n- It enforces the new password length to be between 5 and 15 characters.\n- It disallows a password that is entirely numeric, enforcing the presence of alphabetic characters.\n- It ensures the new password contains at least one numeric character and only allows alphanumeric characters.\n- It inserts the existing recorder row into an audit table for record-keeping and then updates the recorder's password and metadata (last amendment date, changed-by, and password changed date).\n- It returns to caller and grants execute permissions on the procedure to MilkRecordingRole."
        },
        {
         "0": "MilkRecording",
         "1": "dbo",
         "2": "usp1StopImportRecording",
         "3": "CREATE PROCEDURE dbo.usp1StopImportRecording  \t@PID int,  \t@HerdCode varchar(10),  \t@AuthBatchReference int,  \t@BatchReference int,  \t@RecordingDate smalldatetime,  \t@RecordingMethod smallint,  \t@ExtraLines smallint,  \t@Time1 smallint,  \t@Time2 smallint,  \t@Time3 smallint,  \t@FactoringTypeCode char(1),  \t@FactoringMilkingsInBulkTank smallint,  \t@FactoringHowDataEntered smallint,  \t@FactoringYieldAdjustment numeric(9,8),  \t@FactoringFatPcAdjustment numeric(9,8),  \t@FactoringProteinPcAdjustment numeric(9,8),  \t@ArchiveFile varchar(255),  \t@HerdId int output,  \t@NewLoadId int output  \t-- 15/02/2010 J Wall, added uspMrMergeUpdateManualProcessing  \t-- 08/12/2008 J Wall, Removed st@ge tables  \t-- 28/06/2004 J Wall add factoring fields  \t-- Insert a new MilkRecording record form the 1Stop prgram  AS  \tdeclare @LoadDesc varchar(20)  \tSELECT @HerdId = HerdId  \tFROM tblHerds  \tWHERE (OneStopHerdCode = @HerdCode)   \tAND (OneStopPid = @PID)    \t-- Get Unique LoadID  \tselect @LoadDesc = 'HerdId = ' + cast(@HerdId as varchar(6))  \tEXEC uspstageGetNextLoadId '1SRec', @ArchiveFile, @NewLoadId OUTPUT   \t--  \tINSERT INTO Import1StopMilkRecordings  \t\t(LoadId,   \t\tHerdID,   \t\tAuthBatchReference,   \t\tBatchReference,   \t\tRecordingDate,   \t\tRecordingMethod,   \t\tExtraLines,   \t\tTime1,   \t\tTime2,   \t\tTime3,  \t\tFactoringTypeCode ,  \t\tFactoringMilkingsInBulkTank ,  \t\tFactoringHowDataEntered ,  \t\tFactoringYieldAdjustment ,  \t\tFactoringFatPcAdjustment ,  \t\tFactoringProteinPcAdjustment)  \tVALUES       \t\t(@NewLoadId,   \t\t@HerdId,   \t\t@AuthBatchReference,   \t\t@BatchReference,   \t\t@RecordingDate,   \t\t@RecordingMethod,   \t\t@ExtraLines,   \t\t@Time1,   \t\t@Time2,   \t\t@Time3,  \t\t@FactoringTypeCode ,  \t\t@FactoringMilkingsInBulkTank ,  \t\t@FactoringHowDataEntered ,  \t\t@FactoringYieldAdjustment ,  \t\t@FactoringFatPcAdjustment ,  \t\t@FactoringProteinPcAdjustment)  \t  \t--Add the HerdId to the Log record  \tUpdate LoadHistory set  \t\tHerdId=@HerdId  \twhere  \t\t(LoadID=@NewLoadId)      -- set flags for whether recording can be automatically merged when the labs files come in  exec uspMrMergeUpdateManualProcessing @NewLoadId,@HerdId    \t  \tRETURN",
         "4": "1554",
         "5": "2003",
         "6": "1. Stored Procedure Name: usp1StopImportRecording\n2. Stored Procedure Complexity: Medium\n3. Logic can be replicated in Dataverse using Power Automate: Yes\n4. Purpose: Stop the import of a 1Stop Milk Recording by creating a new LoadId, recording the metadata, linking it to the Herd, updating LoadHistory, and triggering a manual merge check.\n5. Summary of stored procedure:\n- It maps the provided HerdCode and PID to the HerdId by querying tblHerds.\n- It prepares a LoadDesc string that includes the HerdId for logging or context.\n- It obtains the next LoadId by executing uspstageGetNextLoadId with the '1SRec' type and the ArchiveFile, returning a NewLoadId.\n- It inserts a new record into Import1StopMilkRecordings with the LoadId, HerdID, authentication and batch references, recording details and factoring fields supplied as parameters.\n- It updates LoadHistory to set the HerdId for the newly created LoadId.\n- It triggers a manual processing merge check by calling uspMrMergeUpdateManualProcessing with the NewLoadId and HerdId.\n- It concludes by returning from the procedure."
        },
