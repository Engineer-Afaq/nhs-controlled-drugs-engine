         "0": "MilkRecording",
         "1": "dbo",
         "2": "uspICARValidationOfMilkRecordsGenerateRows",
         "3": "CREATE PROCEDURE [dbo].[uspICARValidationOfMilkRecordsGenerateRows]  AS  \tSELECT   \t\t*  \tINTO   \t\t#tmp1  \tFROM  \t\tdbo.fn_ICARValidationOfMilkRecords(NULL)    \tSELECT  \t\t*  \tINTO  \t\t#tmp3  \tFROM  \t\t#tmp1  \tWHERE  \t\t1=2    \tSELECT DISTINCT  \t\tAreaManager  \tINTO  \t\t#tmp2  \tFROM  \t\t#tmp1    \tDECLARE  \t\tcur CURSOR LOCAL STATIC  \tFOR  \t\tSELECT  \t\t\tTOP 3 AreaManager  \t\tFROM  \t\t\t#tmp2  \t\tWHERE  \t\t\tAreaManager NOT IN  \t\t\t\t(SELECT  \t\t\t\t\tAreaManager  \t\t\t\t FROM  \t\t\t\t\ttblICARValidationOfMilkRecords  \t\t\t\t WHERE  \t\t\t\t\tYEAR(DateAdded) = YEAR(GETDATE())  \t\t\t\t\tAND MONTH(DateAdded) = MONTH(GETDATE())  \t\t\t\t\tAND ISNULL(Selected, 'Not Chosen') <> 'Not Chosen'  \t\t\t\tGROUP BY  \t\t\t\t\tAreaManager  \t\t\t\t --HAVING  \t\t\t\t\t--COUNT(*) > 1   \t\t\t\t\t)  \t\tORDER BY  \t\t\tNEWID()  \tOPEN  \t\tcur    \tDECLARE  \t\t@AreaManager AS VARCHAR(200)    \tFETCH NEXT FROM  \t\tcur  \tINTO  \t\t@AreaManager  \tWHILE  \t\t(@@FETCH_STATUS <> -1)  \tBEGIN  \t\tINSERT INTO  \t\t\t#tmp3  \t\tSELECT  \t\t\tTOP 1 *  \t\tFROM  \t\t\t#tmp1 data  \t\tWHERE  \t\t\tAreaManager = @AreaManager  \t\t\tAND NOT EXISTS  \t\t\t\t(SELECT  \t\t\t\t\t*  \t\t\t\t FROM  \t\t\t\t\t#tmp3  \t\t\t\t WHERE  \t\t\t\t\tHerdNo = data.HerdNo)  \t\t\tAND NOT EXISTS  \t\t\t\t(SELECT  \t\t\t\t\t*  \t\t\t\t FROM  \t\t\t\t\t#tmp3  \t\t\t\t WHERE  \t\t\t\t\tCounty = data.County)  \t\t\tORDER BY  \t\t\t\tNEWID()  \tFETCH NEXT FROM  \t\tcur  \tINTO  \t\t@AreaManager  \tEND  \tCLOSE cur  \tDEALLOCATE cur    \tINSERT INTO  \t\ttblICARValidationOfMilkRecords  \t\t\t(HerdNo  \t\t\t,RecordingDate  \t\t\t,AreaManager  \t\t\t,County  \t\t\t,FarmName  \t\t\t,SchemeDescription  \t\t\t,SoftwareList)  \tSELECT  \t\t*  \tFROM  \t\t#tmp3        \tDROP TABLE  \t\t#tmp1  \t\t,#tmp2  \t\t,#tmp3  RETURN    GRANT EXECUTE ON [dbo].[uspICARValidationOfMilkRecordsGenerateRows] TO MilkRecordingRole",
