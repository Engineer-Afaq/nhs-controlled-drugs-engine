    "    \"0404000U0\",\"0406000R0\",\"0407010F0\",\"0407010N0\",\"040702040\",\"0407020A0\",\n",
    "    \"0407020AD\",\"0407020AG\",\"0407020B0\",\"0407020C0\",\"0407020G0\",\"0407020H0\",\n",
    "    \"0407020K0\",\"0407020M0\",\"0407020Q0\",\"0407020V0\",\"040801060\",\"0408010AE\",\n",
    "    \"0408010AM\",\"0408010F0\",\"0408010G0\",\"0408010N0\",\"0408010P0\",\"0408020V0\",\n",
    "    \"0408020W0\",\"0410030A0\",\"0410030B0\",\"0410030C0\",\"0604020M0\",\"0604020T0\",\n",
