    "def datastore_search_pages(resource_id: str, filter_field: str, codes: List[str], limit: int = LIMIT):\n",
    "    offset = 0\n",
    "    while True:\n",
    "        params = {\n",
    "            \"resource_id\": resource_id,\n",
    "            \"filters\": json.dumps({filter_field: codes}),  # IMPORTANT: json.dumps -> valid JSON string\n",
    "            \"limit\": limit,\n",
    "            \"offset\": offset\n",
    "        }\n",
    "        payload = http_get_json(DATASTORE_SEARCH, params=params, timeout=240)\n",
    "        records = payload[\"result\"][\"records\"]\n",
    "\n",
    "        if not records:\n",
    "            break\n",
    "\n",
    "        yield records\n",
    "\n",
    "        # last page\n",
    "        if len(records) < limit:\n",
    "            break\n",
    "\n",
    "        offset += limit\n",
    "\n",
    "def records_to_df(records: List[dict]):\n",
    "    rdd = spark.sparkContext.parallelize([json.dumps(r) for r in records])\n",
    "    return spark.read.json(rdd)\n",
    "\n",
    "def normalize_to_canonical(df, canonical_cols: List[str]):\n",
    "    # Drop CKAN internal field if it appears in JSON\n",
    "    if DROP_INTERNAL_ID and \"_id\" in df.columns:\n",
    "        df = df.drop(\"_id\")\n",
    "\n",
    "    # Ensure all canonical columns exist\n",
    "    for c in canonical_cols:\n",
    "        if c not in df.columns:\n",
    "            df = df.withColumn(c, F.lit(None))\n",
    "\n",
    "    # Fix UNIDENTIFIED mismatch: boolean (old) vs text (new) => cast to string\n",
    "    if \"UNIDENTIFIED\" in df.columns:\n",
    "        df = df.withColumn(\"UNIDENTIFIED\", F.col(\"UNIDENTIFIED\").cast(\"string\"))\n",
    "\n",
    "    # For Bronze reliability: cast everything to string to avoid Delta type conflicts\n",
    "    if CAST_ALL_TO_STRING:\n",
    "        for c in canonical_cols:\n",
    "            df = df.withColumn(c, F.col(c).cast(\"string\"))\n",
    "\n",
    "    # Keep only canonical columns in canonical order\n",
    "    df = df.select(*canonical_cols)\n",
    "    return df\n",
    "\n",
    "print(\"Paging + normalization ready.\")"
   ]
  },
