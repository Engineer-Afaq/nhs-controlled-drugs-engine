         "2": "uspLactPredStep2RebuildLactations",
         "3": "  CREATE PROCEDURE dbo.uspLactPredStep2RebuildLactations  \t@YearNo int  -- 28/01/2005 -  called by  uspLactPredRebuildLactationCurves  --  AS  --  -- 1) rebuild the lactations table  --  /*  truncate table LactPredLactations    INSERT INTO LactPredLactations  \t(MrAnimalId,   \tLactationNo,   \tDairyGroupID,   \tintEvaluationGroup,   \tCalvingDate,   \tcalvingmonth,   \tintCountyCode,   \tintCountryCode,   \tPedigreeIndexMkr,   \tintPLI,   \tbreedrange)  SELECT   \tl.MrAnimalId,   \tl.LactationNo,   \tisnull(dgb.DairyGroupID,9),   \tisnull(egb.intEvaluationGroup,1),   \tl.CalvingDate,   \tMONTH(l.CalvingDate),   \th.intCountyCode,   \th.intCountryCode,   \tisnull(pta.PedigreeIndexMkr,'N'),   \tpta.intPLI,  \t'Ave'  FROM animal.dbo.tblPTA pta   RIGHT OUTER JOIN Animal.dbo.tlkpBreedToEvaluationGroup egb   \tON pta.intEvaluationGroup = egb.intEvaluationGroup   \tAND pta.strPublishStatus = 'X'   RIGHT OUTER JOIN tblAnimals a   \tON pta.Animal_ID = a.PtaAnimalId   \tAND egb.strBreedCode = a.Breed   LEFT OUTER JOIN LactPredHerds h   \tON a.HerdId = h.HerdId   LEFT OUTER JOIN Animal.dbo.tlkpDairyGroupBreed dgb   \tON a.Breed = dgb.BreedCode   RIGHT OUTER JOIN tblLactations l   \tON a.MrAnimalId = l.MrAnimalId  WHERE     (l.Qualifying = 1)   AND (ISNULL(l.CalvingDate, DATEADD(year, - 50, GETDATE())) > DATEADD(year, - 5, CONVERT(DATETIME, CAST(@YearNo AS char(4)) + '-01-01 00:00:00', 102)))          */                                RETURN",
