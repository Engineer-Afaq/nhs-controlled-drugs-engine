         "0": "Telreg",
         "1": "dbo",
         "2": "IsEarTagInUse",
         "3": "-- =============================================  -- Author:\t\tLee Davies  -- Create date: 2021-12-07  -- Description:\tSee if eartag is already in the registration tables. Returns the table its in if found  -- =============================================  -- Replaces code in [dbo].[sp_AddNonPedigreeCalf],[sp_AddCalf2],[sp_CheckPassportRequestForCIS]  -- Replaced by [Registration].[dbo].[IsEarTagInUseBatch]  /*  IsEarTagInUse 'UK320579  ','503469',961,205  */  CREATE PROCEDURE [dbo].[IsEarTagInUse]   \t@prefix varchar(10),  \t@suffix varchar(6),  \t@CurrentBatchNo Integer,  \t@CurrentSeqNo Integer  AS  BEGIN  \t-- SET NOCOUNT ON added to prevent extra result sets from  \t-- interfering with SELECT statements.  \tSET NOCOUNT ON;    SELECT TOP 1 UniqueRecId, tableName FROM (  \tSelect TOP 1 UniqueRecId, 'tblBeefCalves' as tableName from tblBeefCalves where eartag1=@prefix and eartag2=@suffix\t\t\t and not (batch_No=@CurrentBatchNo and Seq_No=@CurrentSeqNo)  \tUNION ALL\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t \t\t\t\t\t\t\t--  \tSelect TOP 1 UniqueRecId, 'tarchBeefCalves' as tableName from tarchBeefCalves where eartag1=@prefix and eartag2=@suffix\t\t and not (batch_No=@CurrentBatchNo and Seq_No=@CurrentSeqNo)  \tUNION ALL\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t \t\t\t\t\t\t\t--  \tSelect TOP 1 UniqueRecId, 'tblAllCalves' as tableName from tblAllCalves where eartag1=@prefix and eartag2=@suffix\t\t\t and not (batch_No=@CurrentBatchNo and Seq_No=@CurrentSeqNo)  \tUNION ALL\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t \t\t\t\t\t\t\t--  \tSelect TOP 1 UniqueRecId, 'tblAllCalvesErrors' as tableName from tblAllCalvesErrors where eartag1=@prefix and eartag2=@suffix and not (batch_No=@CurrentBatchNo and Seq_No=@CurrentSeqNo)  \tUNION ALL\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t\t \t\t\t\t\t\t\t--  \tSelect TOP 1 UniqueRecId, 'tarchAllCalves' as tableName from tarchAllCalves where eartag1=@prefix and eartag2=@suffix\t\t and not (batch_No=@CurrentBatchNo and Seq_No=@CurrentSeqNo)  \t-- Ignore if the eartag error was realised on the day of registration and animal deleted  \tand not exists (select * from Animal.dbo.tblAuditAnimalUpdate   \t\twhere AuditType = 'D'  \t\tand ear_tag = ltrim(rtrim(@prefix)) +  ltrim(rtrim(@suffix))  \t\tand convert(char(8), auditdate, 112) = convert(char(8), getdate(), 112)  \t\tand convert(char(8), auditdate, 112) = convert(char(8), tarchAllCalves.DateAdded, 112)  \t\t)  ) AS t  END",
         "4": "1553",
         "5": "2004",
         "6": "1. Stored Procedure Name: IsEarTagInUse\n2. Stored Procedure Complexity: Medium\n3. Logic can be replicated in Dataverse using Power Automate: Yes\n4. Purpose: To determine whether an ear tag (prefix + suffix) is already present in the registration tables and to identify the table containing the record, if found.\n5. Summary of stored procedure:\n- The procedure IsEarTagInUse accepts a prefix and suffix for an ear tag, along with the current batch and sequence numbers.\n- It sets SET NOCOUNT ON to prevent extra result sets from interfering with subsequent statements.\n- It queries for a matching ear tag in the tblBeefCalves table where eartag1 equals the prefix and eartag2 equals the suffix, excluding records that belong to the current batch and sequence.\n- The logic is structured as a derived set that could union multiple registration tables, though in the provided code only tblBeefCalves is active (other tables are present as commented references).\n- It includes a condition to ignore a record if the ear tag issue was realised on the day of registration and the animal was subsequently deleted, by checking the Animal.dbo.tblAuditAnimalUpdate audit log for a deletion today.\n- The query returns the first matching UniqueRecId and the corresponding tableName, allowing the caller to identify where the ear tag is in use.\n- If no matching record is found, the procedure returns no rows."
        }
