         "0": "MilkRecording",
         "1": "dbo",
         "2": "usp1StopMergeScottishLabResults",
         "3": "  CREATE PROCEDURE [dbo].[usp1StopMergeScottishLabResults]  \t@HerdId int,  \t@LabLoadId int,  \t@IgnoreErrors char(1),  \t@RecordingLoadId int OUTPUT  \t--05 Aug 2014 Mitesh, added copy of lab error code to tblTests as well and mark all lab errors as estimated  \t--10/05/2012 J Wall, Aded Barcode to tblCellCountsOnly  \t--22/09/2009 J Wall, Fixed truncated Barcode in error message bug  \t--08/12/2008 J Wall, Removed st@ge tables  \t--17/11/2008 J Wall convert stageCellCountsOnly.CowNo from int to varchar(20)  \t--05/03/2008 J Wall Added Alpha Linenumbers  \t--11/09/2006 J Wall Added Urea/Lactose  \t--25/02/2005 J Wall Move update f LoadHistory to usp1StopFlagScottishLabResultsAsLoaded so not set if there is a timeout on a later step  \t--28/09/2004 J Wall If @IgnoreErrors=\"Y\" and @LabResultsAdded<>0 then just reset the flag  \t--31/08/2004 J Wall merge 1-Stop Scottish Lab results called by StormAdmin.Merge1StopLabs.aspx  AS  declare @RecordingDate smalldateTime  declare @LabResultsAdded tinyint  declare @FactoringMilkingsInBulkTank int  declare @FactoringFatPcAdjustment numeric(9,8)  declare @FactoringProteinPcAdjustment numeric(9,8)  declare @Tank1LineNo as varchar(5)  declare @Tank2LineNo as varchar(5)  declare @Tank3LineNo as varchar(5)    CREATE TABLE #ErrMsg( ErrMsg varchar(255) )    SELECT  TOP 1   \t@RecordingLoadId = LoadID,   \t@RecordingDate = RecordingDate,   \t@LabResultsAdded = isnull(LabResultsAdded,0)  FROM  tblMilkRecordings  WHERE  (HerdId = @HerdId)  ORDER BY RecordingDate DESC    -- check the recording exists and is awaiting lab results  if @@rowcount=0  \tinsert into #ErrMsg( ErrMsg) values('Error - There is no Milk Recording loaded for this herd')  else  \tif @LabResultsAdded<>0  \t\tbegin  \t\t\tif @IgnoreErrors='Y'  \t\t\t\tbegin  \t\t\t\t\tgoto usp1StopMergeScottishLabResults_Exit  \t\t\t\tend    \t\t\telse  \t\t\t\tinsert into #ErrMsg( ErrMsg) values('Error - The latest recording (on ' + cast(@RecordingDate as varchar(12)) + ') already has lab results loaded')  \t\tend      --Check for duplicate linenos  \tinsert into #ErrMsg( ErrMsg)  \tSELECT  'There are ' + cast(COUNT(*) as varchar(5)) + ' Error - Lab results with LineNo = ' + cast(LineNumber as varchar(5))   \tFROM  tblNonRecordedLabResults  \tWHERE  (LoadId = @LabLoadId)  \tand LineNumber<>'0'  \tGROUP BY LineNumber  \tHAVING  (COUNT(*) > 1)  \tORDER BY LineNumber    if exists(select * from #ErrMsg)    \t-- fatal error exit immediately  \tgoto usp1StopMergeScottishLabResults_Exit  else  \tbegin  \t\t--check the all the tests have results  \t\tInsert into #ErrMsg (ErrMsg)  \t\tSELECT    \t\t\t'Warning - There is a test for LineNo=' + dbo.strippedLineNumber(a.LineNumber) + ' but no lab result'  \t\tFROM  tblTests t   \t\tLEFT OUTER JOIN tblAnimals a   \t\t\tON t.MrAnimalID = a.MrAnimalId   \t\tLEFT OUTER JOIN tblNonRecordedLabResults n   \t\t\tON a.LineNumber = dbo.formattedLineNo(n.LineNumber)  \t\t\tAND a.HerdId = n.HerdId   \t\t\tAND n.LoadId = @LabLoadId  \t\tWHERE     (t.LoadID = @RecordingLoadId)   \t\tAND (n.HerdId IS NULL)  \t\tORDER BY a.LineNumber  \t\t--check the all the  results are used  \t\tInsert into #ErrMsg (ErrMsg)  \t\tSELECT    \t\t\t'Warning - There is a Lab Result for LineNo=' + cast(n.LineNumber as varchar(9)) + '(barcode=' + cast(n.Barcode as varchar(25)) + ') but no Test'  \t\tFROM         tblAnimals a   \t\tINNER JOIN tblTests t   \t\t\tON a.MrAnimalId = t.MrAnimalID   \t\t\tAND t.LoadID = @RecordingLoadId   \t\tRIGHT OUTER JOIN tblNonRecordedLabResults n   \t\t\tON a.LineNumber = dbo.formattedLineNo(n.LineNumber)  \t\t\tAND a.HerdId = n.HerdId  \t\tWHERE     (n.LoadId = @LabLoadId)   \t\tAND (a.LineNumber IS NULL)  \t\tand rtrim(isnull(n.LabErrorCode,''))=''  \t\tand n.LineNumber <> '9997'  \t\tand n.LineNumber <> '9998'  \t\tand n.LineNumber <> '9999'  \t\tORDER BY n.LineNumber    \t\t-- check Bulk Tanks  \t\tdeclare @MilkBulkTanks smallint  \t\tdeclare @labBulkTanks smallint  \t\tselect @MilkBulkTanks= case  \t\t\twhen  isnull(Tank1MilkWeight,0) >0 and isnull(Tank2MilkWeight,0) >0 and isnull(Tank3MilkWeight,0) >0 then 3  \t\t\twhen  isnull(Tank1MilkWeight,0) >0 and isnull(Tank2MilkWeight,0) >0  then 2  \t\t\twhen  isnull(Tank1MilkWeight,0) >0 and isnull(Tank3MilkWeight,0) >0  then 2  \t\t\twhen  isnull(Tank2MilkWeight,0) >0 and isnull(Tank3MilkWeight,0) >0  then 2  \t\t\twhen  isnull(Tank1MilkWeight,0) >0 or isnull(Tank2MilkWeight,0) >0 or isnull(Tank3MilkWeight,0) >0 then 1  \t\t\telse 0  \t\t\tend  \t\tFROM tblMilkRecordings WHERE LoadID = @RecordingLoadId  \t\t  \t\tselect @labBulkTanks=count(*)   \t\tfrom tblNonRecordedLabResults n  \t\twhere n.LoadId = @LabLoadId  \t\tand (n.LineNumber = '9997' or n.LineNumber = '9998' or n.LineNumber = '9999')  \t\t  \t\t  \t\tif @MilkBulkTanks<>isnull(@labBulkTanks,0)  \t\t\tinsert into #ErrMsg( ErrMsg)   \t\t\tvalues('Warning - There are ' + cast(@MilkBulkTanks as varchar(2)) + ' bulk tank results, but ' + cast(isnull(@labBulkTanks,0) as varchar(9)) + ' labs (Bulk tank results must be numbered 9997, 9998 or 9999)')  \tend    \t-- return errors and if none merge the labs  \tif not exists(select * from #ErrMsg) or @IgnoreErrors='Y'  \t\tbegin  \t\t\tset XACT_ABORT ON  \t\t\tbegin transaction  \t\t\t\t-- process the recording  \t\t\t\tdelete from #ErrMsg  \t\t\t\t  \t\t\t\tselect   \t\t\t\t\t@HerdId =herdId,  \t\t\t\t\t@FactoringMilkingsInBulkTank = FactoringMilkingsInBulkTank,  \t\t\t\t\t@FactoringFatPcAdjustment =  FactoringFatPcAdjustment,  \t\t\t\t\t@FactoringProteinPcAdjustment = FactoringProteinPcAdjustment  \t\t\t\tfrom tblMilkRecordings  \t\t\t\twhere loadId=@RecordingLoadId  \t\t\t\t  \t\t\t\t--Update tests  \t\t\t\tUpdate t set       \t\t\t\t\tt.ButterFatPercent = n.BFatPC * @FactoringFatPcAdjustment,  \t\t\t\t\tt.ProteinPercent = n.ProtPC * @FactoringProteinPcAdjustment,   \t\t\t\t\tt.CellCount = n.CellCount,  \t\t\t\t\tt.Urea = n.Urea,  \t\t\t\t\tt.Lactose = n.Lactose  \t\t\t\t\t,t.LabErrorCode = n.LabErrorCode  \t\t\t\tFROM   tblAnimals a   \t\t\t\tINNER JOIN tblTests t   \t\t\t\t\tON a.MrAnimalId = t.MrAnimalID   \t\t\t\t\tAND t.LoadID = @RecordingLoadId   \t\t\t\tINNER JOIN  tblNonRecordedLabResults n   \t\t\t\t\tON a.LineNumber = dbo.formattedLineNo(n.LineNumber)  \t\t\t\t\tAND a.HerdId = n.HerdId  \t\t\t\tWHERE (n.LoadId = @LabLoadId)    \t\t\t\tUpdate tblTests set  \t\t\t\t\tResultType=1  \t\t\t\twhere  LoadID = @RecordingLoadId  \t\t\t\tand (ISNULL(ButterFatPercent,0)=0 OR ISNULL(LabErrorCode, '') <> '')  \t\t\t\t  \t\t\t\t--Update recording  \t\t\t\tupdate tblMilkRecordings set  LabResultsAdded=1 where LoadId =  @RecordingLoadId  \t\t\t\t-- Flag Batch as Processed  \t\t\t\tUPDATE LoadHistory  \t\t\t\tSET   OneStopScottishLabsMerged = 'Y'  \t\t\t\tWHERE (LoadId = @LabLoadId)    \t\t\t\tif @MilkBulkTanks>0 and isnull(@labBulkTanks,0)>0  \t\t\t\t\tbegin  \t\t\t\t\t\tif isnull(@FactoringMilkingsInBulkTank,0) <> 1  \t\t\t\t\t\t\tselect @FactoringFatPcAdjustment=1, @FactoringProteinPcAdjustment=1    \t\t\t\t\t\tselect @Tank1LineNo = MAX(LineNumber)  \t\t\t\t\t\tFROM  tblNonRecordedLabResults  \t\t\t\t\t\tWHERE (LoadId = @LabLoadId)  \t\t\t\t\t\tand (LineNumber = '9999' OR LineNumber = '9998' OR LineNumber = '9997')  \t\t\t\t\t\tif @@rowcount>0  \t\t\t\t\t\t\tselect @Tank2LineNo = MAX(LineNumber)  \t\t\t\t\t\t\tFROM  tblNonRecordedLabResults  \t\t\t\t\t\t\tWHERE (LoadId = @LabLoadId)  \t\t\t\t\t\t\tand LineNumber < @Tank1LineNo  \t\t\t\t\t\t\tand (LineNumber = '9999' OR LineNumber = '9998' OR LineNumber = '9997')  \t\t\t\t\t\tif @@rowcount>0  \t\t\t\t\t\t\tselect @Tank3LineNo = MAX(LineNumber)  \t\t\t\t\t\t\tFROM  tblNonRecordedLabResults  \t\t\t\t\t\t\tWHERE (LoadId = @LabLoadId)  \t\t\t\t\t\t\tand LineNumber < @Tank2LineNo  \t\t\t\t\t\t\tand (LineNumber = '9999' OR LineNumber = '9998' OR LineNumber = '9997')  \t\t\t\t\t\tif \t@Tank1LineNo is not null\t\t\t  \t\t\t\t\t\t\tUpdate r set  \t\t\t\t\t\t\t\tr.Tank1ButterFatPercent = isnull(n.BFatPc,0) * @FactoringFatPcAdjustment,   \t\t\t\t\t\t\t\tr.Tank1ProteinPercent = isnull(n.ProtPc,0) * @FactoringProteinPcAdjustment,   \t\t\t\t\t\t\t\tr.Tank1CellCount = isnull(n.CellCount,0),  \t\t\t\t\t\t\t\tr.Tank1Urea = isnull(n.Urea,0),  \t\t\t\t\t\t\t\tr.Tank1Lactose = isnull(n.Lactose,0)  \t\t\t\t\t\t\tFROM tblMilkRecordings r   \t\t\t\t\t\t\tINNER JOIN tblNonRecordedLabResults n   \t\t\t\t\t\t\t\tON r.HerdId = n.HerdId   \t\t\t\t\t\t\t\tAND n.LoadId = @LabLoadId  \t\t\t\t\t\t\tWHERE r.LoadID = @RecordingLoadId   \t\t\t\t\t\t\tAND (n.LineNumber = @Tank1LineNo)\t\t\t\t\t  \t\t\t\t\t\tif \t@Tank2LineNo is not null\t\t\t  \t\t\t\t\t\t\tUpdate r set  \t\t\t\t\t\t\t\tr.Tank2ButterFatPercent = isnull(n.BFatPc,0) * @FactoringFatPcAdjustment,   \t\t\t\t\t\t\t\tr.Tank2ProteinPercent = isnull(n.ProtPc,0) * @FactoringProteinPcAdjustment,   \t\t\t\t\t\t\t\tr.Tank2CellCount = isnull(n.CellCount,0),  \t\t\t\t\t\t\t\tr.Tank2Urea = isnull(n.Urea,0),  \t\t\t\t\t\t\t\tr.Tank2Lactose = isnull(n.Lactose,0)   \t\t\t\t\t\t\tFROM tblMilkRecordings r   \t\t\t\t\t\t\tINNER JOIN tblNonRecordedLabResults n   \t\t\t\t\t\t\t\tON r.HerdId = n.HerdId   \t\t\t\t\t\t\t\tAND n.LoadId = @LabLoadId  \t\t\t\t\t\t\tWHERE r.LoadID = @RecordingLoadId   \t\t\t\t\t\t\tAND (n.LineNumber = @Tank2LineNo)\t\t\t\t\t  \t\t\t\t\t\tif \t@Tank3LineNo is not null\t\t\t  \t\t\t\t\t\t\tUpdate r set  \t\t\t\t\t\t\t\tr.Tank3ButterFatPercent = isnull(n.BFatPc,0) * @FactoringFatPcAdjustment,   \t\t\t\t\t\t\t\tr.Tank3ProteinPercent = isnull(n.ProtPc,0) * @FactoringProteinPcAdjustment,   \t\t\t\t\t\t\t\tr.Tank3CellCount = isnull(n.CellCount,0),  \t\t\t\t\t\t\t\tr.Tank3Urea = isnull(n.Urea,0),  \t\t\t\t\t\t\t\tr.Tank3Lactose = isnull(n.Lactose,0)  \t\t\t\t\t\t\tFROM tblMilkRecordings r   \t\t\t\t\t\t\tINNER JOIN tblNonRecordedLabResults n   \t\t\t\t\t\t\t\tON r.HerdId = n.HerdId   \t\t\t\t\t\t\t\tAND n.LoadId = @LabLoadId  \t\t\t\t\t\t\tWHERE r.LoadID = @RecordingLoadId   \t\t\t\t\t\t\tAND (n.LineNumber = @Tank3LineNo)\t\t\t\t\t  \t\t\t\t\tend  \t\t\t\t\t-- add any extra labs to cell counts only  \t\t\t\t\tINSERT INTO tblCellCountsOnly  \t\t\t\t\t(LoadId,   \t\t\t\t\tMilkRecordingLoadId,   \t\t\t\t\tHerdId,   \t\t\t\t\tSampleSeqNo,   \t\t\t\t\tCowNo,   \t\t\t\t\tBFatPc,   \t\t\t\t\tProtPc,   \t\t\t\t\tCellCount,  \t\t\t\t\tUrea,  \t\t\t\t\tLactose,   \t\t\t\t\tLabErrorCode,  \t\t\t\t\tBarcode)  \t\t\t\t\tSELECT       \t\t\t\t\t\t@LabLoadId,   \t\t\t\t\t\t@RecordingLoadId,   \t\t\t\t\t\tn.HerdId,   \t\t\t\t\t\tn.SampleSeqNo,   \t\t\t\t\t\tn.LineNumber,   \t\t\t\t\t\tn.BFatPc,   \t\t\t\t\t\tn.ProtPc,   \t\t\t\t\t\tn.CellCount,   \t\t\t\t\t\tn.Urea,   \t\t\t\t\t\tn.Lactose,   \t\t\t\t\t\tn.LabErrorCode,  \t\t\t\t\t\tn.Barcode  \t\t\t\t\tFROM         tblAnimals a   \t\t\t\t\tINNER JOIN tblTests t   \t\t\t\t\t\tON a.MrAnimalId = t.MrAnimalID   \t\t\t\t\t\tAND t.LoadID = @RecordingLoadId   \t\t\t\t\tRIGHT OUTER JOIN tblNonRecordedLabResults n   \t\t\t\t\t\tON a.LineNumber = dbo.formattedLineNo(n.LineNumber)  \t\t\t\t\t\tAND a.HerdId = n.HerdId  \t\t\t\t\tWHERE     (n.LoadId = @LabLoadId)   \t\t\t\t\tAND (a.CisCowNo IS NULL)  \t\t\t\t\tand rtrim(isnull(n.LabErrorCode,''))=''  \t\t\t\t\tand n.LineNumber <> '9997'  \t\t\t\t\tand n.LineNumber <> '9998'  \t\t\t\t\tand n.LineNumber <> '9999'  \t\t\tcommit transaction  \t\tend  \telse  \t\t  \t\t    usp1StopMergeScottishLabResults_Exit:  \tselect * from #ErrMsg    RETURN",
