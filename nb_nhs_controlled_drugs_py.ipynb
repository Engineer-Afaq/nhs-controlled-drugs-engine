         "2": "uspMatchEartagsStep3",
         "3": "  CREATE PROCEDURE [dbo].[uspMatchEartagsStep3]  \t@StepNo INT  --25 April 2014 Mitesh do not use animal.dbo.StrippedEarTag in join, very bad performance! Created extra column on tmp table and updated instead  --01/11/2007 J Wall added \"Ignore special characters\" section  --02/01/2005 J Wall Match Dard Eartags   AS    UPDATE  \ttmpDardEartagMatch  SET  \tStrippedEarTag = animal.dbo.StrippedEarTag(EarMarkToMatch)  WHERE  \tStrippedEarTag IS NULL    Update e set  \te.MatchedAnimal_ID = a.Animal_Id,   \tTypeOfMatch = @StepNo  FROM tmpDardEartagMatch\te  Inner Join Animal.dbo.tblAllAnimals a  \ton e.EarMarkToMatch = a.Ear_Mark  where e.MatchedAnimal_ID is null    -- Ignore special characters  Update e set  \te.MatchedAnimal_ID = a.Animal_Id,   \tTypeOfMatch = @StepNo  FROM tmpDardEartagMatch\te  Inner Join Animal.dbo.tblAllAnimals a  \t--//XI0: Remove XI  \tON REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(REPLACE(e.EarMarkToMatch, 'UK', ''), ' ', ''), '-', ''), '/', '') , 'NL', '') , 'DE', ''), 'XI', '')  \t\t= a.Ear_Mark  where e.MatchedAnimal_ID is null    --try Stripped eartag  Update e set  \te.MatchedAnimal_ID = a.Animal_Id,   \tTypeOfMatch = @StepNo  FROM tmpDardEartagMatch\te  Inner Join Animal.dbo.tblAllAnimals a  \t--ON animal.dbo.StrippedEarTag(e.EarMarkToMatch)\t\t= a.StrippedEarTag  \tON e.StrippedEarTag = a.StrippedEarTag  where e.MatchedAnimal_ID is null    RETURN",
