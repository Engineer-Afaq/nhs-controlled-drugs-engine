         "2": "uspAIUpdateSemenStocks",
         "3": "CREATE PROCEDURE [dbo].[uspAIUpdateSemenStocks]  \t@CustomerID int,  \t@BatchID int,  \t@MrSireId int,  \t@BatchNo varchar(25),  \t@DatePurchased smalldatetime,  \t@UnitsPurchased int,  \t@UnitsDiscarded decimal(9, 1),  \t@PurchasePrice decimal(9, 2),  \t@PriceBand char(1),  \t@LocationCustomerID int,  \t@Comments varchar(2000),  \t@User varchar(255),  \t@ErrMsg varchar(255) output  AS  -- 23/06/2009 J Wall, Added CustomerID  -- 26/05/2009 J Wall, used by AISemenStocks.aspx   \tselect @ErrMsg=''  \tif @BatchID is null  \t\tINSERT INTO tblAISemenStocks  \t\t\t(CustomerID,   \t\t\tMrSireId,   \t\t\tBatchNo,   \t\t\tDatePurchased,   \t\t\tUnitsPurchased,   \t\t\tUnitsDiscarded,   \t\t\tPurchasePrice,   \t\t\tPriceBand,   \t\t\tLocationCustomerID,   \t\t\tComments)    \t\tVALUES       \t\t\t(@CustomerID,   \t\t\t@MrSireId,   \t\t\t@BatchNo,   \t\t\t@DatePurchased,   \t\t\t@UnitsPurchased,   \t\t\t@UnitsDiscarded,   \t\t\t@PurchasePrice,   \t\t\t@PriceBand,   \t\t\t@LocationCustomerID,   \t\t\t@Comments)  \telse  \t\tBegin  \t\t\tInsert into audittblAISemenStocks  \t\t\tSelect *,GetDate(),@User,'U'  \t\t\tfrom tblAISemenStocks  \t\t\tWhere BatchID=@BatchID  \t\t\t  \t\t\tUPDATE tblAISemenStocks SET  \t\t\t\tCustomerID=@CustomerID,   \t\t\t\tMrSireId=@MrSireId,   \t\t\t\tBatchNo=@BatchNo,   \t\t\t\tDatePurchased=@DatePurchased,   \t\t\t\tUnitsPurchased=@UnitsPurchased,   \t\t\t\tUnitsDiscarded=@UnitsDiscarded,   \t\t\t\tPurchasePrice=@PurchasePrice,   \t\t\t\tPriceBand=@PriceBand,   \t\t\t\tLocationCustomerID=@LocationCustomerID,   \t\t\t\tComments =@Comments  \t\t\tWhere BatchID=@BatchID  \t\tend    \tRETURN",
