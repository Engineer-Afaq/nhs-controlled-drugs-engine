     "text": [
      "Resources: 58\n",
      "First: ['EPD_SNOMED_202101', 'EPD_SNOMED_202102', 'EPD_SNOMED_202103'] Last: ['EPD_SNOMED_202508', 'EPD_SNOMED_202509', 'EPD_SNOMED_202510']\n"
