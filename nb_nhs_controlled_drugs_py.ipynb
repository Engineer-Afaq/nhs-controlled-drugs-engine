         "2": "uspLivelistTestHistory",
         "3": "CREATE PROCEDURE [dbo].[uspLivelistTestHistory]  \t@HerdId int,  \t@Startdate smalldatetime,  \t@Enddate smalldatetime  AS  -- 08/10/2008 J Wall List All Tests for a herd between 2 dates  \tSET NOCOUNT ON;  SELECT   \tr.RecordingDate,   \t--FormattedRecDate=convert(varchar(12),r.RecordingDate, 6),  \tt.MrAnimalID,  \ta.CisCowNo,   \tEarTag = dbo.FullEartag(a.CisEarTagPrefix, a.EarTag),   \tAnimalName = LTRIM(RTRIM(a.Prefix)) + ' ' + a.AnimalName,   \tdbo.FormattedName3(a.Prefix, a.AnimalName, '', '', '', a.CisEarTagPrefix, a.Eartag, 20) AS shortname,   \tt.LactationNo,   \tyield = cast(isnull(t.Recording1,0.0) +   \t\tisnull(t.Recording2,0.0)+   \t\tisnull(t.Recording3,0.0) as numeric(5,1)),   \tt.ButterFatPercent,   \tt.ProteinPercent,   \tt.Urea,   \tt.lactose,   \tt.CellCount,   \tt.ResultType,   \tt.LabErrorCode,  \tLabErrorDescription=isnull(e.LabErrorDescription,''),   \tResultTypeDesc=replace(replace(isnull(rt.ResultTypeDesc,''),', Constituent ',''),', Full Sick','')  FROM tblTests  t  INNER JOIN tblMilkRecordings r  \tON t.LoadID = r.LoadID  Inner Join tblAnimals a  \ton t.MrAnimalID= a.MrAnimalID  LEFT OUTER JOIN tlkpLabErrors e  \tON t.LabErrorCode = e.LabErrorCode   LEFT OUTER JOIN tlkpTestResultTypes rt  \tON t.ResultType = rt.ResultTypeCode  where t.HerdId=@HerdId  and r.RecordingDate >= @Startdate  and r.RecordingDate <= @Enddate  and isnull(r.ServerGeneratedDummyRecording,'N')='N'",
